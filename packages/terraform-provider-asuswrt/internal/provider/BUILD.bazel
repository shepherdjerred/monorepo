load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "provider",
    srcs = [
        "dhcp_static_lease_resource.go",
        "nvram_data_source.go",
        "nvram_resource.go",
        "port_forward_resource.go",
        "provider.go",
        "system_resource.go",
        "wireless_network_resource.go",
    ],
    importpath = "github.com/shepherdjerred/terraform-provider-asuswrt/internal/provider",
    visibility = ["//packages/terraform-provider-asuswrt:__subpackages__"],
    deps = [
        "//packages/terraform-provider-asuswrt/internal/client",
        "@com_github_hashicorp_terraform_plugin_framework//datasource",
        "@com_github_hashicorp_terraform_plugin_framework//datasource/schema",
        "@com_github_hashicorp_terraform_plugin_framework//diag",
        "@com_github_hashicorp_terraform_plugin_framework//path",
        "@com_github_hashicorp_terraform_plugin_framework//provider",
        "@com_github_hashicorp_terraform_plugin_framework//provider/schema",
        "@com_github_hashicorp_terraform_plugin_framework//resource",
        "@com_github_hashicorp_terraform_plugin_framework//resource/schema",
        "@com_github_hashicorp_terraform_plugin_framework//resource/schema/int64planmodifier",
        "@com_github_hashicorp_terraform_plugin_framework//resource/schema/planmodifier",
        "@com_github_hashicorp_terraform_plugin_framework//resource/schema/stringplanmodifier",
        "@com_github_hashicorp_terraform_plugin_framework//types",
        "@com_github_hashicorp_terraform_plugin_log//tflog",
    ],
)

# Internal test (package provider) — tests helpers that access unexported symbols
go_test(
    name = "provider_internal_test",
    srcs = ["helpers_test.go"],
    embed = [":provider"],
    deps = [
        "//packages/terraform-provider-asuswrt/internal/client",
        "@com_github_hashicorp_terraform_plugin_framework//types",
    ],
)

# External test (package provider_test) — acceptance tests using mock servers
go_test(
    name = "provider_test",
    srcs = [
        "dhcp_static_lease_resource_test.go",
        "mock_server_test.go",
        "nvram_data_source_test.go",
        "nvram_resource_test.go",
        "port_forward_resource_test.go",
        "provider_test.go",
        "system_resource_test.go",
        "wireless_network_resource_test.go",
    ],
    env = {"TF_ACC": "1"},
    deps = [
        ":provider",
        "//packages/terraform-provider-asuswrt/internal/client",
        "@com_github_hashicorp_terraform_plugin_framework//providerserver",
        "@com_github_hashicorp_terraform_plugin_go//tfprotov6",
        "@com_github_hashicorp_terraform_plugin_testing//helper/resource",
    ],
)
