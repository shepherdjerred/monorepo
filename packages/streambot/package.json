{
  "name": "@shepherdjerred/streambot",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "true",
    "test": "bun test",
    "e2e": "bun run e2e/run.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dank074/discord-video-stream": "6.0.0",
    "discord.js": "^14.26.4",
    "discord.js-selfbot-v13": "^3.7.1",
    "xstate": "^5.32.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@lng2004/node-datachannel",
    "node-av",
    "unrs-resolver"
  ]
