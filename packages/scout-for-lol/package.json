{
  "name": "scout-for-lol",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='./packages/*' build",
    "typecheck": "bun run --filter='./packages/*' typecheck",
    "lint": "bun run --filter='./packages/*' lint",
    "lint:ci": "bunx eslint packages/ --format json --output-file eslint-report.json || true",
    "format": "bun run --filter='./packages/*' format",
    "test": "bun run --filter='./packages/*' test",
    "clean": "rm -rf node_modules packages/*/node_modules",
    "generate": "bun run --cwd packages/backend generate",
    "knip": "knip-bun",
    "knip:ci": "knip-bun --reporter json > knip-report.json || true",
    "duplication-check": "bun run scripts/check-duplication.ts"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.13",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "bun-types": "latest",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-import-resolver-typescript-bun": "^0.0.104",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "jiti": "^2.6.1",
    "jscpd": "^4.0.9",
    "knip": "^6.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "autoprefixer": "^10.5.0",
    "openai": "^6.34.0",
    "react": "^19.2.5",
    "twisted": "^1.73.0",
    "zod": "^4.3.6"
  },
  "patchedDependencies": {
    "twisted@1.73.0": "patches/twisted@1.73.0.patch"
  }
}
