{
  "name": "@scout-for-lol/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint src",
    "format": "bunx prettier --check src",
    "format:write": "bunx prettier --write src"
  },
  "dependencies": {
    "@scout-for-lol/data": "file:../data",
    "react": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "bun-types": "latest",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "19.2.6"
  },
  "imports": {
    "#src/*": "./src/*"
  }
}
