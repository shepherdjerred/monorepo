load("@bun_modules//:defs.bzl", "bun_link_all_packages")
load("//tools/oci:bun_service_image.bzl", "bun_service_image")
load("//tools/rules_bun/bun:defs.bzl", "bun_binary", "bun_eslint_test", "bun_library", "bun_prisma_generate", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

bun_link_all_packages(name = "node_modules")

exports_files([
    "package.json",
    "tsconfig.json",
])

# Prisma client generation (run explicitly: bazel build //packages/birmel:prisma_generate)
bun_prisma_generate(
    name = "prisma_generate",
    schema = "prisma/schema.prisma",
)

bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@ai-sdk/openai",
        ":node_modules/@opentelemetry/api",
        ":node_modules/@opentelemetry/exporter-trace-otlp-http",
        ":node_modules/@opentelemetry/resources",
        ":node_modules/@opentelemetry/sdk-node",
        ":node_modules/@opentelemetry/semantic-conventions",
        ":node_modules/@prisma/client",
        ":node_modules/@sentry/node",
        ":node_modules/@types/bun",
        ":node_modules/@voltagent/core",
        ":node_modules/@voltagent/libsql",
        ":node_modules/ai",
        ":node_modules/chrono-node",
        ":node_modules/cron-parser",
        ":node_modules/discord.js",
        ":node_modules/discord-player",
        ":node_modules/discord-player-youtubei",
        ":node_modules/hono",
        ":node_modules/mediaplex",
        ":node_modules/playwright",
        ":node_modules/youtubei.js",
        ":node_modules/zod",
    ],
)

bun_binary(
    name = "birmel",
    entry_point = "src/index.ts",
    deps = [":pkg"],
)

bun_eslint_test(
    name = "lint",
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    prisma_client = ":prisma_generate",
    deps = [
        ":node_modules/prisma",
        ":node_modules/typescript",
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/undici-types",
        "//packages/eslint-config:pkg",
    ],
)

bun_typecheck_test(
    name = "typecheck",
    extra_files = ["//:tsconfig.base.json"],
    prisma_client = ":prisma_generate",
    tags = ["requires-network"],
    tsconfig = "tsconfig.json",
    deps = [
        ":node_modules/@types/bun",
        ":node_modules/prisma",
        ":node_modules/typescript",
        ":pkg",
        "//:node_modules/undici-types",
    ],
)

# Prisma is resolved via PRISMA_SCHEMA env + bun_test_runner.sh.
# Still manual: integration tests need many transitive deps not yet available
# in sandbox (e.g., @opentelemetry/context-async-hooks, database setup).
bun_test(
    name = "test",
    data = ["prisma/schema.prisma"],
    env = {"PRISMA_SCHEMA": "prisma/schema.prisma"},
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
    ],
)

# Container image for K8s deployment
bun_service_image(
    name = "image",
    srcs = glob(["src/**/*.ts"]) + [
        "package.json",
        "prisma/schema.prisma",
    ],
    entry_point = "src/index.ts",
    env = {"NODE_ENV": "production"},
    labels = {
        "org.opencontainers.image.title": "birmel",
        "org.opencontainers.image.description": "AI-powered Discord server management bot",
        "org.opencontainers.image.source": "https://github.com/shepherdjerred/monorepo",
    },
    package_json = "package.json",
    repository = "ghcr.io/shepherdjerred/birmel",
    visibility = ["//visibility:public"],
)
