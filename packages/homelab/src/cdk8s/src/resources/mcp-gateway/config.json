{
  "mcpProxy": {
    "addr": ":9090",
    "name": "MCP Gateway",
    "version": "1.0.0",
    "options": {
      "authTokens": ["MCP_PROXY_AUTH_TOKEN_PLACEHOLDER"]
    }
  },
  "mcpServers": {
    "canvas": {
      "command": "npx",
      "args": ["-y", "@r-huijts/canvas-mcp@1.0.8"]
    },
    "home-assistant": {
      "command": "uvx",
      "args": [
        "mcp-proxy",
        "--transport=streamablehttp",
        "--stateless",
        "https://homeassistant.tailnet-1a49.ts.net/api/mcp"
      ]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "sonos": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/WinstonFassett/sonos-mcp-server.git",
        "sonos-mcp-server"
      ]
    },
    "fastmail": {
      "command": "npx",
      "args": ["-y", "@jahfer/jmap-mcp-server"]
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@automatearmy/email-reader-mcp"]
    },
    "edstem": {
      "command": "node",
      "args": ["/opt/edstem-mcp/dist/index.js"]
    },
    "gradescope": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Yuanpeng-Li/gradescope-mcp.git@1e9743be7de62b14f9a6ddc843e2789ba6eb6d6e",
        "gradescope-mcp"
      ]
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "mcp-discord@1.3.4"]
    }
  }
}
