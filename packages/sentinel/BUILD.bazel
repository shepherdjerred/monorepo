load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/oci:bun_service_image.bzl", "bun_service_image")
load("//tools/rules_bun/bun:defs.bzl", "bun_binary", "bun_eslint_test", "bun_library", "bun_prisma_generate")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files([
    "package.json",
    "tsconfig.json",
])

# Prisma client generation (run explicitly: bazel build //packages/sentinel:prisma_generate)
bun_prisma_generate(
    name = "prisma_generate",
    schema = "prisma/schema.prisma",
)

# Bun-native: TypeScript executed directly by Bun, no transpilation needed.
bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@anthropic-ai/claude-agent-sdk",
        ":node_modules/@prisma/client",
        ":node_modules/@sentry/bun",
        ":node_modules/@trpc/server",
        ":node_modules/cron",
        ":node_modules/discord.js",
        ":node_modules/gray-matter",
        ":node_modules/hono",
        ":node_modules/pino",
        ":node_modules/zod",
    ],
)

bun_binary(
    name = "sentinel",
    entry_point = "src/index.ts",
    deps = [":pkg"],
)

bun_eslint_test(
    name = "lint",
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    deps = [
        ":pkg",
        "//:node_modules/@types/bun",
        "//packages/eslint-config:pkg",
    ],
)

# Prisma types require prisma generate.
bun_typecheck_test(
    name = "typecheck",
    extra_files = ["//:tsconfig.base.json"],
    prisma_client = ":prisma_generate",
    tags = [
        "manual",
        "requires-network",
    ],
    tsconfig = "tsconfig.json",
    deps = [
        ":node_modules/@types/bun",
        ":node_modules/prisma",
        ":node_modules/typescript",
        ":pkg",
        "//:node_modules/undici-types",
    ],
)

# Container image for K8s deployment
bun_service_image(
    name = "image",
    srcs = glob(["src/**/*.ts"]) + [
        "package.json",
        "prisma/schema.prisma",
    ],
    entry_point = "src/index.ts",
    env = {"NODE_ENV": "production"},
    labels = {
        "org.opencontainers.image.title": "sentinel",
        "org.opencontainers.image.description": "Autonomous agent system for operational task automation",
        "org.opencontainers.image.source": "https://github.com/shepherdjerred/monorepo",
    },
    package_json = "package.json",
    repository = "ghcr.io/shepherdjerred/sentinel",
    visibility = ["//visibility:public"],
)
