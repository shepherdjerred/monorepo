+// Re-apply the host-latched controller state into neilbuttons[*]. Must run AFTER
+// resetNeilButtons()/overlay reset and BEFORE retro_run() in mainLoopInner.
+void applyHostControls()
+{
+    for (int player = 0; player < NEILNUMCONTROLLERS; player++)
+    {
+        NeilHostPad& pad = g_neilHostPads[player];
+        if (!pad.active) continue;
+        if (pad.buttons[0])  neilbuttons[player].upKey    = true;
+        if (pad.buttons[1])  neilbuttons[player].downKey  = true;
+        if (pad.buttons[2])  neilbuttons[player].leftKey  = true;
+        if (pad.buttons[3])  neilbuttons[player].rightKey = true;
+        if (pad.buttons[4])  neilbuttons[player].aKey     = true;
+        if (pad.buttons[5])  neilbuttons[player].bKey     = true;
+        if (pad.buttons[6])  neilbuttons[player].startKey = true;
+        if (pad.buttons[7])  neilbuttons[player].zKey     = true;
+        if (pad.buttons[8])  neilbuttons[player].lKey     = true;
+        if (pad.buttons[9])  neilbuttons[player].rKey     = true;
+        if (pad.buttons[10]) neilbuttons[player].cbUp     = true;
+        if (pad.buttons[11]) neilbuttons[player].cbDown   = true;
+        if (pad.buttons[12]) neilbuttons[player].cbLeft   = true;
+        if (pad.buttons[13]) neilbuttons[player].cbRight  = true;
+        neilbuttons[player].axis0 = pad.axis0;
+        neilbuttons[player].axis1 = pad.axis1;
+    }
+}
