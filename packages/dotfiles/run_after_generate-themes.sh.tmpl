#!/bin/bash
set -euo pipefail
{{ if eq .chezmoi.os "darwin" -}}
if ! command -v whiskers &>/dev/null; then
    echo "ERROR: whiskers not installed; cannot generate fish theme env files." >&2
    echo "Install with: cargo install catppuccin-whiskers   (or: brew install whiskers)" >&2
    exit 1
fi

TERA_FILE="{{ .chezmoi.sourceDir }}/private_dot_config/private_fish/conf.d/theme-env.fish.tera"
OUT_DIR="$HOME/.config/fish/conf.d"

if [[ ! -f "$TERA_FILE" ]]; then
    echo "ERROR: tera template not found at $TERA_FILE" >&2
    exit 1
fi

mkdir -p "$OUT_DIR"
cd "$OUT_DIR"
whiskers "$TERA_FILE"
{{ end -}}
