{
  "name": "@discord-plays-mario-kart/backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#generated/*": "./generated/*"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "build": "bunx tsc",
    "watch": "bunx tsc --watch",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "lint": "bun run lint:check",
    "lint:fix": "bun run lint:eslint:fix",
    "lint:check": "bun run lint:eslint:check",
    "lint:eslint:check": "bunx eslint .",
    "lint:eslint:fix": "bunx eslint . --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build:wasm": "bash ../../scripts/build-wasm.sh",
    "e2e:input": "bun run scripts/e2e-input.ts",
    "e2e:input:check": "bun run scripts/e2e-input-assert.ts",
    "e2e:perf": "bun run scripts/e2e-perf.ts",
    "e2e:perf:browser": "bun run scripts/e2e-perf-browser.ts",
    "e2e:race": "bun run scripts/e2e-race.ts",
    "e2e:scenario": "bun run scripts/e2e-scenario.ts",
    "e2e:audio": "bun run scripts/e2e-audio.ts",
    "generate": "bunx --trust prisma generate",
    "db:push": "bunx prisma db push"
  },
  "dependencies": {
    "@discord-plays-mario-kart/common": "file:../common",
    "@libsql/client": "0.17.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@sentry/bun": "^10.0.0",
    "@shepherdjerred/discord-stream-lifecycle": "file:../../../discord-stream-lifecycle",
    "@shepherdjerred/discord-video-stream": "file:../../../discord-video-stream",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "discord.js-selfbot-v13": "^3.6.1",
    "express": "^5.0.0",
    "lodash": "4.18.1",
    "prom-client": "^15.1.3",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "smol-toml": "1.6.1",
    "socket.io": "^4.8.1",
    "ts-pattern": "^5.7.0",
    "winston": "^3.17.0",
    "xstate": "^5.32.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shepherdjerred/eslint-config": "file:../../../eslint-config",
    "@tsconfig/recommended": "1.0.13",
    "@types/bun": "^1.3.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/lodash": "^4.17.16",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.1",
    "prisma": "^7.8.0",
    "socket.io-client": "^4.8.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.50.0"
  }
}
