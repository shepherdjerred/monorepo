{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    // Every RN native module must be linked in the iOS project (old CI:
    // tasks-for-obsidian-ios-native-deps). Runs against the workspace install —
    // the legacy per-package hoisted-install dance is no longer needed.
    "check:ios-native-deps": {
      "inputs": [
        "package.json",
        "ios/**",
        "!ios/Pods/**",
        "!ios/build/**",
        "scripts/check-ios-native-deps.ts"
      ]
    },
    // swiftlint --strict, same as the old CI swift-lint step. Needs the
    // swiftlint binary (mise optional tool set / CI toolchain image).
    "lint:swift": {
      "inputs": ["ios/**/*.swift", ".swiftlint.yml"]
    },
    // Wire-contract suite: the app's real TaskNotesClient against a spawned
    // real tasknotes-server over a temp vault (old CI: tasknotes-contract-test).
    // Hermetic — no creds, no build artifact (the server runs from source).
    // turbo `inputs` cannot reach outside the package (`../` is invalid), so the
    // tasknotes-server coupling is expressed as a task dependency instead: a
    // server change invalidates this task via that task's hash.
    "test:contract": {
      "dependsOn": ["tasknotes-server#typecheck"],
      "inputs": ["contract-tests/**", "src/data/**", "src/domain/**"]
    }
  }
}
