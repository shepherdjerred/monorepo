{
  "name": "@shepherdjerred/docs-board",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "bun run src/dev.ts",
    "launch": "bun run build && bun run src/server/index.ts --open",
    "start": "bun run src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "bunx eslint . --max-warnings=0",
    "check-docs": "bun run src/cli/check-docs.ts",
    "migrate-docs": "bun run src/cli/migrate-docs.ts"
  },
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#server/*": "./src/server/*.ts",
    "#shared/*": "./src/shared/*.ts",
    "#styles/*": "./src/styles/*"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@fontsource-variable/geist": "^5.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@trpc/tanstack-react-query": "^11.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.18",
    "lucide-react": "^1.14.0",
    "mdast-util-to-string": "^4.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "^1.3.12",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "shadcn": "^4.14.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
