{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      // resume.pdf is this task's OUTPUT — gitignored (xelatex output is
      // nondeterministic: it embeds CreationDate, so it must never be hashed
      // as an input) and restored from the turbo cache. CI builds it in the
      // resume-build step's texlive container and ships it as a Buildkite
      // artifact for the deploy-sites step.
      "outputs": ["*.pdf"]
    }
  }
}
