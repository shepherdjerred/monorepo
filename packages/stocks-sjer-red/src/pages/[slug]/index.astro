---
import Layout from "@layouts/Layout.astro";
import StockChart from "@components/StockChart.astro";
import {
  portfolio,
  currentPrice,
  avgPurchasePrice,
  costBasis,
  quantity,
  lineTotal,
  pctChange,
  sortedHistory,
  formatUsd,
  formatUsdCents,
  formatPct,
} from "@data/load";
import type { Component } from "@data/schema";

export function getStaticPaths() {
  return portfolio.components.map((c) => ({
    params: { slug: c.slug },
    props: { component: c },
  }));
}

interface Props {
  component: Component;
}

const { component } = Astro.props;
const cur = currentPrice(component);
const avgBuy = avgPurchasePrice(component);
const pct = pctChange(avgBuy, cur);
const total = lineTotal(component);
const basis = costBasis(component);
const qty = quantity(component);
const isUp = pct >= 0;
const color = isUp ? "var(--color-up)" : "var(--color-down)";
const history = sortedHistory(component);
const peak = Math.max(...history.map((p) => p.price));
const trough = Math.min(...history.map((p) => p.price));
const purchases = [...component.purchases].sort((a, b) =>
  a.date.localeCompare(b.date),
);
---

<Layout title={`${component.name} - Homelab - sjer.red`}>
  <a
    href="/"
    class="text-[var(--color-muted)] text-xs uppercase tracking-wider hover:text-[var(--color-amber)]"
  >
    ← Portfolio
  </a>

  <section
    class="border border-[var(--color-line)] bg-[var(--color-panel)] p-6 mt-4 mb-6"
  >
    <div class="grid gap-4 sm:flex sm:items-start sm:justify-between mb-4">
      <div class="flex gap-4 items-start min-w-0">
        {
          component.imageUrl ? (
            <img
              src={component.imageUrl}
              alt=""
              loading="lazy"
              decoding="async"
              class="detail-hero-image"
            />
          ) : (
            <div class="detail-hero-image row-thumb-placeholder">
              {component.category}
            </div>
          )
        }
        <div class="min-w-0">
          <div
            class="text-[var(--color-muted)] text-xs uppercase tracking-widest mb-1 break-words"
          >
            {component.category} · {component.manufacturer} · {
              component.partNumber
            }
          </div>
          <h1 class="text-xl sm:text-2xl font-semibold leading-tight">
            {component.name}
          </h1>
          {
            component.productUrl && (
              <a
                href={component.productUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[var(--color-muted)] hover:text-[var(--color-amber)] text-xs uppercase tracking-wider"
              >
                view product page →
              </a>
            )
          }
        </div>
      </div>
      <div
        class="text-left sm:text-right border-t border-[var(--color-line)] pt-4 sm:border-t-0 sm:pt-0"
      >
        <div class="text-2xl sm:text-3xl font-semibold tabular-nums">
          {formatUsdCents(cur)}
        </div>
        <div class="text-lg tabular-nums" style={`color: ${color}`}>
          <span>{formatPct(pct)}</span>
          <span class="text-[var(--color-muted)] text-sm">
            vs. avg buy {formatUsdCents(avgBuy)}
          </span>
        </div>
      </div>
    </div>

    <StockChart
      history={history}
      width={1100}
      height={340}
      ariaLabel={`${component.name} price history`}
    />

    <div
      class="grid grid-cols-2 sm:grid-cols-5 gap-x-6 gap-y-2 mt-6 pt-4 border-t border-[var(--color-line)] text-sm tabular-nums"
    >
      <div>
        <div class="text-[var(--color-muted)] text-xs uppercase tracking-wider">
          Quantity
        </div>
        <div>{qty}</div>
      </div>
      <div>
        <div class="text-[var(--color-muted)] text-xs uppercase tracking-wider">
          Unit
        </div>
        <div>{formatUsdCents(cur)}</div>
      </div>
      <div>
        <div class="text-[var(--color-muted)] text-xs uppercase tracking-wider">
          Line total
        </div>
        <div class="font-semibold">{formatUsd(total)}</div>
      </div>
      <div>
        <div
          class="text-[var(--color-muted)] text-xs uppercase tracking-wider"
          title="Highest market price in this dataset."
        >
          52w high
        </div>
        <div>{formatUsdCents(peak)}</div>
      </div>
      <div>
        <div
          class="text-[var(--color-muted)] text-xs uppercase tracking-wider"
          title="Lowest market price in this dataset."
        >
          52w low
        </div>
        <div>{formatUsdCents(trough)}</div>
      </div>
    </div>
  </section>

  <section
    class="border border-[var(--color-line)] bg-[var(--color-panel)] mb-6"
  >
    <div
      class="px-4 py-3 text-[var(--color-muted)] text-xs uppercase tracking-wider border-b border-[var(--color-line)]"
    >
      Purchases · cost basis {formatUsdCents(basis)}
    </div>
    <table class="w-full text-sm tabular-nums">
      <thead>
        <tr
          class="text-[var(--color-muted)] text-xs uppercase tracking-wider border-b border-[var(--color-line)]"
        >
          <th class="text-left px-4 py-2 font-normal">Date</th>
          <th class="text-right px-4 py-2 font-normal">Qty</th>
          <th class="text-right px-4 py-2 font-normal">Unit paid</th>
          <th class="text-right px-4 py-2 font-normal">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        {
          purchases.map((p) => (
            <tr class="border-b border-[var(--color-line)] last:border-0">
              <td class="px-4 py-2">{p.date}</td>
              <td class="px-4 py-2 text-right">{p.quantity}</td>
              <td class="px-4 py-2 text-right">
                {formatUsdCents(p.pricePaid)}
              </td>
              <td class="px-4 py-2 text-right font-semibold">
                {formatUsd(p.quantity * p.pricePaid)}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <section class="border border-[var(--color-line)] bg-[var(--color-panel)]">
    <div
      class="px-4 py-3 text-[var(--color-muted)] text-xs uppercase tracking-wider border-b border-[var(--color-line)]"
    >
      Price history · {history.length} datapoints
    </div>
    <table class="w-full text-sm tabular-nums">
      <thead>
        <tr
          class="text-[var(--color-muted)] text-xs uppercase tracking-wider border-b border-[var(--color-line)]"
        >
          <th class="text-left px-4 py-2 font-normal">Date</th>
          <th class="text-right px-4 py-2 font-normal">Price</th>
          <th class="text-right px-4 py-2 font-normal">Chg</th>
        </tr>
      </thead>
      <tbody>
        {
          history.map((p, i) => {
            const prev = history[i - 1];
            const delta = prev ? p.price - prev.price : 0;
            const deltaPct = prev ? pctChange(prev.price, p.price) : 0;
            const deltaColor =
              delta === 0
                ? "var(--color-muted)"
                : delta > 0
                  ? "var(--color-up)"
                  : "var(--color-down)";
            return (
              <tr class="border-b border-[var(--color-line)] last:border-0">
                <td class="px-4 py-2">{p.date}</td>
                <td class="px-4 py-2 text-right">{formatUsdCents(p.price)}</td>
                <td class="px-4 py-2 text-right" style={`color: ${deltaColor}`}>
                  {prev ? formatPct(deltaPct) : "—"}
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </section>
</Layout>
