---
import { Icon } from "astro-icon/components";
import {
  changelog,
  formatChangelogDate,
  renderChangelogToHtml,
} from "../data/changelog";

const latestEntry = changelog[0];
---

{
  latestEntry && (
    <div class="bg-indigo-600 dark:bg-indigo-700 text-white relative z-40">
      <div class="mx-auto max-w-7xl px-4 py-2 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between gap-x-6">
          <div class="flex items-center gap-x-3 min-w-0 flex-1">
            <Icon
              name="heroicons:megaphone"
              class="h-5 w-5 flex-none text-white"
            />
            <p class="text-sm leading-6 text-white truncate">
              <strong class="font-semibold">
                What's New - {formatChangelogDate(latestEntry)}:
              </strong>{" "}
              {renderChangelogToHtml(latestEntry.banner).replace(/<[^>]*>?/gm, '')}
            </p>
          </div>
          <a
            href="/whatsnew"
            class="flex-none text-sm font-semibold text-white hover:text-white/80 transition-colors whitespace-nowrap"
          >
            View all <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  )
}
