load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/rules_bun/bun:defs.bzl", "bun_library", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# Produce .d.ts declarations so downstream ts_project deps can type-check.
ts_project(
    name = "types",
    srcs = glob(
        ["src/**/*.ts"],
        exclude = ["src/**/*.test.ts"],
    ),
    declaration = True,
    emit_declaration_only = True,
    extends = "//:tsconfig_base",
    out_dir = "dist",
    root_dir = "src",
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    validate = False,
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@clauderon/shared",
        ":node_modules/@types/bun",
    ],
)

bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        "//packages/clauderon/web/shared:pkg",
    ],
)

eslint_test(
    name = "lint",
    size = "small",
    srcs = glob(["src/**/*.ts"]),
)

bun_typecheck_test(
    name = "typecheck",
    tags = ["manual"],
    extra_files = ["//:tsconfig.base.json"],
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
        ":node_modules/@clauderon/shared",
        ":node_modules/@types/bun",
        ":node_modules/typescript",
    ],
)

bun_test(
    name = "test",
    size = "small",
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
    ],
)
