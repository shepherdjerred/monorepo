{
  "name": "@shepherdjerred/birmel",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "bun run generate && bunx prisma db push && bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "true",
    "generate": "bun run scripts/generate-prisma.ts",
    "test": "bun --env-file=.env.test run generate && bun --env-file=.env.test test",
    "test:e2e:music": "bun run e2e/music-playback.ts",
    "test:e2e:youtube-stream": "bun run e2e/youtube-stream-resource.ts",
    "test:e2e:openclaw-docker": "bun run e2e/openclaw-capabilities-docker.ts",
    "typecheck": "bun run generate && tsc --noEmit",
    "lint": "bun run generate && eslint ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@anthropic-ai/claude-agent-sdk": "^0.3.145",
    "@libsql/client": "0.17.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/bun": "^10.49.0",
    "@shepherdjerred/llm-observability": "file:../llm-observability",
    "@snazzah/davey": "^0.1.11",
    "@voltagent/core": "^2.7.4",
    "@voltagent/libsql": "^2.1.2",
    "ai": "^6.0.180",
    "chrono-node": "^2.9.1",
    "cron-parser": "^5.5.0",
    "discord-player": "7.2.0",
    "discord-player-youtubei": "^2.0.0",
    "discord.js": "^14.26.4",
    "ffmpeg-static": "^5.3.0",
    "hono": "^4.12.18",
    "mediaplex": "^1.0.0",
    "playwright": "^1.60.0",
    "youtube-dl-exec": "^3.1.6",
    "youtubei.js": "^17.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.1",
    "axios": "1.16.1",
    "fast-uri": "3.1.2",
    "protobufjs": "8.0.3",
    "esbuild": "0.28.1",
    "@grpc/grpc-js": "1.14.4"
  }
}
