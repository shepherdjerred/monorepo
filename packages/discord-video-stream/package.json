{
  "name": "@shepherdjerred/discord-video-stream",
  "version": "6.0.0-fork.0",
  "description": "Monorepo fork of @dank074/discord-video-stream with a seekable player and a bun-safe lazy sharp import",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*",
      "default": "./src/*"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@lng2004/node-datachannel": "0.32.0-20260202",
    "@snazzah/davey": "^0.1.8",
    "debug-level": "^4.1.1",
    "fluent-ffmpeg": "^2.1.3",
    "node-av": "^5.2.2",
    "p-debounce": "^5.1.0",
    "sharp": "^0.35.0",
    "zeromq": "^6.5.0"
  },
  "peerDependencies": {
    "discord.js-selfbot-v13": "^3.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25",
    "discord.js-selfbot-v13": "^3.7.1",
    "typescript": "^6.0.3"
  }
}
