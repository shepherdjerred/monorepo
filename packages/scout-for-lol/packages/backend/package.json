{
  "name": "@scout-for-lol/backend",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./generated/*": "./generated/*"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external=ffmpeg-static",
    "test": "DATABASE_URL=${DATABASE_URL:-file:./test.db} bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:threshold": "bun test --coverage --bail",
    "test:ci": "bun test --bail --reporter=junit --reporter-outfile=./junit.xml",
    "test:fast": "bun test --bail=3",
    "test:debug": "bun test --randomize",
    "lint": "bunx eslint src",
    "format": "bunx prettier --check src",
    "format:write": "bunx prettier --write src",
    "typecheck": "bunx tsc --noEmit",
    "generate": "bun run db:generate",
    "compact:report-lake": "bun run scripts/compact-report-lake.ts",
    "generate-lane-priors": "bun run scripts/generate-lane-priors.ts",
    "evaluate-lane-priors": "bun run scripts/evaluate-lane-priors.ts",
    "db:generate": "bunx --trust prisma generate && bun run brand-types && bunx prettier --write generated/ && bun run generate:test-template",
    "generate:test-template": "RUST_LOG=info bun run scripts/generate-test-template-db.ts",
    "check:test-template": "bun run scripts/check-test-template-db.ts",
    "brand-types": "bun run scripts/brand-prisma-types.ts",
    "db:push": "bunx prisma db push",
    "db:migrate": "bunx prisma migrate dev",
    "db:studio": "bunx prisma studio",
    "import:report-store:s3": "bun run scripts/import-report-store-from-s3.ts",
    "discover:marketing-showcase": "bun run scripts/discover-marketing-showcase.ts",
    "generate:marketing-showcase": "bun run scripts/generate-marketing-showcase.ts",
    "test:review": "bun run src/league/review/test-reviews.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1001.0",
    "@discordjs/voice": "^0.19.0",
    "@duckdb/node-api": "1.5.4-r.1",
    "@google/generative-ai": "^0.24.0",
    "@libsql/client": "0.17.3",
    "@mastra/core": "^1.49.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@scout-for-lol/data": "file:../data",
    "@scout-for-lol/report": "file:../report",
    "@sentry/bun": "^10.0.0",
    "@shepherdjerred/llm-observability": "file:../../../llm-observability",
    "@trpc/server": "11",
    "cron": "^4.1.4",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.0.1",
    "env-var": "^7.5.0",
    "jose": "^6.2.3",
    "openai": "^6.9.1",
    "prism-media": "^1.3.5",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "react": "19.2.6",
    "remeda": "^2.21.2",
    "sodium-native": "^5.0.10",
    "ts-pattern": "^5.7.0",
    "tslog": "^4.10.2",
    "twisted": "^1.73.0",
    "uuid": "^14.0.0",
    "yoga-wasm-web": "^0.3.3",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "bun-types": "latest",
    "glob": "^13.0.0",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3"
  },
  "description": "Backend service for Scout for League of Legends Discord bot",
  "keywords": [
    "discord",
    "bot",
    "league-of-legends",
    "typescript",
    "bun"
  ],
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shepherdjerred/monorepo.git"
  },
  "homepage": "https://github.com/shepherdjerred/monorepo/tree/main/packages/scout-for-lol",
  "bugs": {
    "url": "https://github.com/shepherdjerred/monorepo/issues"
  },
  "imports": {
    "#src/*": "./src/*",
    "#generated/*": "./generated/*"
  }
}
