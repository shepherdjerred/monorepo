---
import "../../styles/global.css";
import SeoHead from "#src/components/SeoHead.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description="Review Generator Development Tool"
      noindex
    />
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-slate-950 dark:text-white">
    <slot />
  </body>
</html>
