load("@bun_modules//:defs.bzl", "bun_link_all_packages")
load("//tools/rules_bun/bun:defs.bzl", "bun_eslint_test", "bun_library", "bun_test", "bun_vite_build")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

bun_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# .gitkeep ensures the dist/ directory exists in the source tree for
# include_dir! in Rust compilation. Force-added to git despite .gitignore.
exports_files(
    ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "dist_gitkeep",
    srcs = ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

bun_vite_build(
    name = "vite_build",
    extra_files = [
        "vite.config.ts",
        "tsconfig.json",
        "//:tsconfig.base.json",
        "postcss.config.js",
        "tailwind.config.js",
        "index.html",
    ],
    deps = [":pkg"],
)

# Vite/React SPA; this bun_library wraps sources for dependency tracking.
bun_library(
    name = "pkg",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
        ],
        exclude = [
            "**/*.test.ts",
            "**/*.test.tsx",
            "**/*.spec.ts",
            "**/*.spec.tsx",
        ],
    ),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/react",
        ":node_modules/react-dom",
        ":node_modules/zod",
        "//packages/clauderon/web/client:pkg",
        "//packages/clauderon/web/shared:pkg",
    ],
)

# Manual: TypeShare-generated types resolve as 'error' in eslint-typescript sandbox
bun_eslint_test(
    name = "lint",
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    node_modules = ":node_modules",
    tags = ["manual"],
    deps = [
        ":node_modules/typescript",
        ":node_modules/vite",
        ":pkg",
        "//:node_modules/@types/bun",
        "//packages/eslint-config:pkg",
    ],
)

# Manual: @clauderon/shared exports dist/ types which aren't available in sandbox
bun_typecheck_test(
    name = "typecheck",
    extra_files = ["//:tsconfig.base.json"],
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    deps = [
        ":node_modules/@types/bun",
        ":node_modules/typescript",
        ":node_modules/vite",
        ":pkg",
    ],
)

bun_test(
    name = "test",
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
    ],
)
