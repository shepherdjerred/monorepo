#!/usr/bin/env python3
import sys
import json

sys.stdin.read()

{{- $bunxCmd := "bunx" -}}
{{- if eq .chezmoi.os "darwin" }}
bunx_cmd = "{{ printf "%s/.local/share/mise/shims/bunx" .chezmoi.homeDir }}"
{{- else }}
bunx_cmd = "bunx"
{{- end }}

data = {
    "ui": {
        "theme": "GitHub Light"
    },
    "mcpServers": {
        "playwright": {
            "command": bunx_cmd,
            "args": ["-y", "@playwright/mcp"]
        }
    }
}

json.dump(data, sys.stdout, indent=2, sort_keys=True)
sys.stdout.write("\n")
