{
  "name": "@shepherdjerred/home-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "ha-codegen": "./src/codegen/cli.ts"
  },
  "imports": {
    "#shared/*": "./src/shared/*",
    "#schema/*": "./src/schema/*",
    "#codegen/*": "./src/codegen/*",
    "#rest/*": "./src/rest/*",
    "#ws/*": "./src/ws/*",
    "#lib": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache .",
    "test": "bun test"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/recommended": "^1.0.13",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.13",
    "eslint": "^10.0.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.3"
  }
}
