#!/bin/bash
DESIRED='{{
  dict
    "mcpServers" (includeTemplate "claude-mcp-servers.json.tmpl" . | fromJson)
    "preferences" (dict "coworkScheduledTasksEnabled" false "sidebarMode" "task")
  | toPrettyJson
}}'
if [ -s /dev/stdin ]; then
  jq -s '.[0] * .[1]' /dev/stdin <(echo "$DESIRED")
else
  echo "$DESIRED" | jq .
fi
