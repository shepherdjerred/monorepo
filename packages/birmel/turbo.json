{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    // Tests read a gitignored .env.test — declared as an explicit input so its
    // CONTENTS participate in the task hash (turbo stores the hash, not the
    // file). If turbo can't hash ignored files, this must revert to cache:false.
    "test": {
      "env": ["NODE_ENV"],
      "inputs": ["$TURBO_DEFAULT$", ".env.test"]
    },
    // generate-prisma.ts evaluates the database config module.
    "generate": {
      "env": ["DATABASE_URL", "DATABASE_PATH", "LOG_LEVEL"]
    }
  }
}
