{
  "name": "tasks-for-obsidian",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "bun test src scripts",
    "test:contract": "bun test contract-tests --timeout 20000",
    "e2e": "bun run e2e/run.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check:ios-native-deps": "bun scripts/check-ios-native-deps.ts",
    "check:release-bundle": "bun scripts/check-release-bundle.ts",
    "pod-install": "cd ios && pod install",
    "clean:ios": "bash scripts/clean-ios.sh",
    "ios:logs": "bash scripts/ios-logs.sh"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-menu/menu": "^2.0.0",
    "@react-native-vector-icons/feather": "^13.1.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@sentry/react-native": "^8.8.0",
    "react": "19.2.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-haptic-feedback": "^3.0.0",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-keychain": "^10.0.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "^4.3.0",
    "react-native-worklets": "^0.8.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-sound": "^0.13.0",
    "tasknotes-types": "file:../tasknotes-types",
    "zeego": "^3.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/react": "~19.2.14",
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "patchedDependencies": {
    "react-native-sound@0.13.0": "patches/react-native-sound@0.13.0.patch",
    "react-native-ios-utilities@5.2.0": "patches/react-native-ios-utilities@5.2.0.patch"
  },
  "overrides": {
    "fast-xml-builder": "1.2.0",
    "shell-quote": "1.8.4"
