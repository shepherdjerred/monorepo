{
  "name": "@shepherdjerred/leetcode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape:list": "bun run src/scrape-list.ts",
    "scrape:details": "bun run src/scrape-details.ts",
    "build": "bun run build:db && bun run build:search",
    "build:db": "bun run src/build-db.ts",
    "build:search": "bun run src/build-search-index.ts",
    "search": "bun run src/search.ts",
    "lint": "bunx eslint --cache .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "workspace:*",
    "@types/bun": "^1.3.13",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3"
  }
}
