---
import Button from "#src/components/Button.astro";
import type { DiscordCtaLocation } from "#src/lib/marketing.ts";
import type { DiscordInstallClickEvent } from "#src/lib/marketing-constants.ts";

type TrackingButtonProps =
  | {
      trackingEvent: DiscordInstallClickEvent;
      trackingLocation: DiscordCtaLocation;
    }
  | {
      trackingEvent?: undefined;
      trackingLocation?: undefined;
    };

type HeroCtaButton = {
  text: string;
  href: string;
  variant?: "primary" | "secondary";
} & TrackingButtonProps;

interface Props {
  title: string;
  subtitle?: string;
  showGradient?: boolean;
  ctaButtons?: HeroCtaButton[];
}

const { title, subtitle, showGradient = true, ctaButtons = [] } = Astro.props;
---

<div class="relative isolate px-6 pt-14 lg:px-8">
  {
    showGradient && (
      <div
        class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80"
        aria-hidden="true"
      >
        <div
          class="relative left-[calc(50%-11rem)] aspect-1155/678 w-144.5 -translate-x-1/2 rotate-30 bg-linear-to-tr from-[#ff80b5] to-[#9089fc] opacity-30 sm:left-[calc(50%-30rem)] sm:w-288.75"
          style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
        />
      </div>
    )
  }

  <div class="mx-auto max-w-2xl py-32 sm:py-48 lg:py-56">
    <div class="text-center">
      <h1
        class="text-balance text-5xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-7xl"
      >
        {title}
      </h1>
      {
        subtitle && (
          <p class="mt-8 text-pretty text-lg font-medium text-gray-500 dark:text-gray-400 sm:text-xl/8">
            {subtitle}
          </p>
        )
      }
      {
        ctaButtons.length > 0 && (
          <div class="mt-10 flex items-center justify-center gap-x-6">
            {ctaButtons.map((button) => {
              if (button.trackingEvent === undefined) {
                return button.variant === "secondary" ? (
                  <Button
                    href={button.href}
                    variant="text"
                    color="indigo"
                    class="text-sm text-indigo-400 hover:text-indigo-300"
                  >
                    {button.text}
                  </Button>
                ) : (
                  <Button href={button.href} size="lg">
                    {button.text}
                  </Button>
                );
              }

              return button.variant === "secondary" ? (
                <Button
                  href={button.href}
                  variant="text"
                  color="indigo"
                  class="text-sm text-indigo-400 hover:text-indigo-300"
                  trackingEvent={button.trackingEvent}
                  trackingLocation={button.trackingLocation}
                >
                  {button.text}
                </Button>
              ) : (
                <Button
                  href={button.href}
                  size="lg"
                  trackingEvent={button.trackingEvent}
                  trackingLocation={button.trackingLocation}
                >
                  {button.text}
                </Button>
              );
            })}
          </div>
        )
      }
    </div>
  </div>
</div>
