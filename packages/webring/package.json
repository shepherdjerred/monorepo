    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^10.0.0",
    "express": "^5.2.1",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "typedoc": "^0.28.19",
