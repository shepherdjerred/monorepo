{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["bun"],
    "module": "NodeNext",
    "target": "ESNext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@shepherdjerred/discord-stream-lifecycle": [
        "../../../discord-stream-lifecycle/src/index.ts"
      ],
      "@shepherdjerred/discord-stream-lifecycle/*": [
        "../../../discord-stream-lifecycle/src/*"
      ],
      "@shepherdjerred/discord-video-stream": [
        "../../../discord-video-stream/src/index.ts"
      ],
      "@shepherdjerred/discord-video-stream/*": [
        "../../../discord-video-stream/src/*"
      ]
    }
  },
  "exclude": [
    "eslint.config.ts",
    "generated",
    "src/config/index.test.ts",
    "src/emulator/constants.test.ts",
    "src/emulator/png.test.ts",
    "src/input/input-latency-tracker.test.ts",
    "src/stream/overlay.test.ts",
    "src/stream/stream-observer.test.ts",
    "src/webserver/dispatch.test.ts"
  ]
}
