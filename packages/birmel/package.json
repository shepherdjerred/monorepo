{
  "name": "@shepherdjerred/birmel",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "bunx prisma db push && bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "true",
    "generate": "bunx --trust prisma@6 generate",
    "test": "bunx --env-file=.env.test --trust prisma@6 generate && bun --env-file=.env.test test",
    "typecheck": "bunx --trust prisma@6 generate && tsc --noEmit",
    "lint": "bunx --trust prisma@6 generate && eslint ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.49.0",
    "@voltagent/core": "^2.7.2",
    "@voltagent/libsql": "^2.1.2",
    "ai": "^6.0.168",
    "chrono-node": "^2.9.0",
    "cron-parser": "^5.5.0",
    "discord-player": "7.2.0",
    "discord-player-youtubei": "^2.0.0",
    "youtube-dl-exec": "^3.1.5",
    "discord.js": "^14.26.3",
    "hono": "^4.12.14",
    "mediaplex": "^1.0.0",
    "playwright": "^1.59.1",
    "youtubei.js": "^17.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/utils": "^8.59.0",
    "eslint": "^9.39.4",
    "jiti": "^2.6.1",
    "prisma": "^6.19.3",
    "typescript": "^6.0.3"
  }
}
