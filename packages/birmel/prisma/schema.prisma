generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "sqlite"
}

model DailyPostConfig {
  id         Int       @id @default(autoincrement())
  guildId    String    @unique
  channelId  String
  enabled    Boolean   @default(true)
  postTime   String    @default("09:00")
  timezone   String    @default("UTC")
  lastPostAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ServerEvent {
  id        Int      @id @default(autoincrement())
  guildId   String
  eventType String
  eventData String
  actorId   String?
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
}

model ScheduledAnnouncement {
  id          Int       @id @default(autoincrement())
  guildId     String
  channelId   String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  repeat      String?
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([guildId])
  @@index([scheduledAt])
}

model MusicHistory {
  id        Int      @id @default(autoincrement())
  guildId   String
  trackUrl  String
  trackName String
  duration  Int
  userId    String
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
}

model PollRecord {
  id          Int      @id @default(autoincrement())
  guildId     String
  channelId   String
  messageId   String   @unique
  pollId      String
  question    String
  createdBy   String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([guildId, createdAt])
}

model UserActivity {
  id           Int      @id @default(autoincrement())
  guildId      String
  userId       String
  channelId    String
  activityType String
  metadata     String?
  createdAt    DateTime @default(now())

  @@index([guildId, userId, createdAt])
  @@index([guildId, activityType, createdAt])
}

model Birthday {
  id         Int      @id @default(autoincrement())
  userId     String
  guildId    String
  birthMonth Int
  birthDay   Int
  birthYear  Int?
  timezone   String   @default("UTC")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, guildId])
  @@index([guildId, birthMonth, birthDay])
}

model GuildOwner {
  id             Int       @id @default(autoincrement())
  guildId        String    @unique
  currentOwner   String
  nickname       String
  lastElectionAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ElectionPoll {
  id             Int       @id @default(autoincrement())
  guildId        String
  channelId      String
  messageId      String?
  pollType       String
  status         String
  scheduledStart DateTime
  scheduledEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?
  candidates     String
  winner         String?
  voteCounts     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([guildId, status])
  @@index([scheduledStart])
}

model ScheduledTask {
  id          Int       @id @default(autoincrement())
  guildId     String
  channelId   String?
  userId      String
  scheduledAt DateTime
  cronPattern String?
  naturalDesc String?
  toolId      String?
  toolInput   String?
  executedAt  DateTime?
  nextRun     DateTime?
  enabled     Boolean   @default(true)
  name        String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([guildId])
  @@index([enabled, scheduledAt])
}

model AgentJob {
  id              String        @id @default(uuid())
  guildId         String
  channelId       String?
  threadId        String?
  userId          String
  name            String?
  description     String?
  scheduleKind    String
  scheduleValue   String
  timezone        String        @default("UTC")
  nextRunAt       DateTime?
  status          String        @default("active")
  payloadKind     String        @default("tool")
  message         String?
  toolId          String?
  toolInput       String?
  deliveryMode    String        @default("discord")
  model           String?
  reasoningEffort String?
  textVerbosity   String?
  maxAttempts     Int           @default(3)
  timeoutMs       Int           @default(300000)
  attemptCount    Int           @default(0)
  lastRunAt       DateTime?
  lastStatus      String?
  lastError       String?
  legacyTaskId    Int?          @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  runs            AgentJobRun[]

  @@index([guildId, status])
  @@index([status, nextRunAt])
  @@index([channelId])
  @@index([threadId])
}

model AgentJobRun {
  id         String    @id @default(uuid())
  jobId      String
  job        AgentJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  output     String?
  error      String?
  metadata   String?
  createdAt  DateTime  @default(now())

  @@index([jobId, startedAt])
  @@index([status, startedAt])
}

model AgentSession {
  id              String              @id @default(uuid())
  guildId         String
  channelId       String
  threadId        String?
  userId          String
  label           String?
  status          String              @default("active")
  steeringPolicy  String              @default("steer")
  model           String?
  reasoningEffort String?
  textVerbosity   String?
  summary         String?
  expiresAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  events          AgentSessionEvent[]

  @@index([guildId, status])
  @@index([channelId, status])
  @@index([threadId, status])
  @@index([userId, status])
}

model AgentSessionEvent {
  id        String       @id @default(uuid())
  sessionId String
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  eventType String
  content   String
  metadata  String?
  createdAt DateTime     @default(now())

  @@index([sessionId, createdAt])
  @@index([eventType, createdAt])
}

model AgentMemory {
  id          String   @id @default(uuid())
  guildId     String
  scope       String
  ownerKey    String?
  channelId   String?
  userId      String?
  sessionId   String?
  key         String?
  content     String
  tags        String?
  sourceType  String?
  sourceId    String?
  salience    Float    @default(0.5)
  embedding    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([guildId, scope])
  @@index([channelId])
  @@index([userId])
  @@index([sessionId])
  @@index([updatedAt])
}

model EditorSession {
  id              String    @id @default(uuid())
  userId          String
  guildId         String
  channelId       String
  threadId        String?
  messageId       String?
  repoName        String
  sdkSessionId    String?
  clonedRepoPath  String?   // Path to cloned repo in /tmp
  state           String    @default("active")
  pendingChanges  String?
  summary         String?
  prUrl           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  expiresAt       DateTime

  @@index([userId, state])
  @@index([guildId])
  @@index([threadId])
}

model GitHubAuth {
  id           String    @id @default(uuid())
  userId       String    @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
