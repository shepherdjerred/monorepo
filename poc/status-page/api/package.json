{
  "name": "@shepherdjerred/status-page-api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bunx prisma db push --skip-generate && bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "prisma generate && bunx eslint . --max-warnings=0",
    "build": "true",
    "test": "true"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "hono": "^4.12.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "workspace:*",
    "@types/bun": "^1.3.10",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.53.1"
  }
}
