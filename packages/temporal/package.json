{
  "name": "@shepherdjerred/temporal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#shared/*": "./src/shared/*",
    "#activities/*": "./src/activities/*",
    "#workflows/*": "./src/workflows/*"
  },
  "scripts": {
    "start": "bun run src/worker.ts",
    "build": "tsc",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache .",
    "test": "bun test src/activities",
    "test:integration": "bun test src/integration.test.ts"
  },
  "dependencies": {
    "@shepherdjerred/home-assistant": "file:../home-assistant",
    "firebase": "^12.5.0",
    "@kubernetes/client-node": "^1.1.2",
    "@sentry/bun": "^10.0.0",
    "@temporalio/activity": "^1.12.2",
    "@temporalio/client": "^1.12.2",
    "@temporalio/worker": "^1.12.2",
    "@temporalio/workflow": "^1.12.2",
    "openai": "^6.10.0",
    "simple-git": "^3.30.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/recommended": "^1.0.11",
    "@tsconfig/strictest": "^2.0.7",
    "@types/bun": "^1.3.10",
    "eslint": "^9.39.2",
    "jiti": "^2.6.1",
    "typescript": "^6"
  }
}
