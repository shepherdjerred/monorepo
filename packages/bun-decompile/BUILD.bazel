load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/rules_bun/bun:defs.bzl", "bun_binary", "bun_library", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@anthropic-ai/sdk",
        ":node_modules/@anthropic-ai/tokenizer",
        ":node_modules/@babel/core",
        ":node_modules/@babel/generator",
        ":node_modules/@babel/parser",
        ":node_modules/@babel/plugin-syntax-jsx",
        ":node_modules/@babel/plugin-syntax-typescript",
        ":node_modules/@babel/traverse",
        ":node_modules/@babel/types",
        ":node_modules/acorn",
        ":node_modules/acorn-walk",
        ":node_modules/openai",
        ":node_modules/tiktoken",
        ":node_modules/zod",
    ],
)

bun_binary(
    name = "bun_decompile",
    entry_point = "src/index.ts",
    deps = [":pkg"],
)

eslint_test(
    name = "lint",
    srcs = glob(["src/**/*.ts"]),
)

bun_typecheck_test(
    name = "typecheck",
    tsconfig = "tsconfig.json",
    extra_files = ["//:tsconfig.base.json"],
    deps = [
        ":pkg",
        ":node_modules/@types/babel__core",
        ":node_modules/@types/babel__generator",
        ":node_modules/@types/babel__traverse",
        ":node_modules/typescript",
        "//:node_modules/@types/bun",
        "//:node_modules/undici-types",
    ],
)

# Requires bun build --compile (local execution) and Bun >= 1.3.10 for
# sourcemap recovery. Toolchain is 1.3.9; unmark once updated.
bun_test(
    name = "test",
    tsconfig = "tsconfig.json",
    local = True,
    tags = ["manual"],
    deps = [":pkg"],
)
