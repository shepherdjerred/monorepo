{
  "name": "tasknotes-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile=dist/tasknotes-server",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "bunx eslint . --max-warnings=0"
  },
  "dependencies": {
    "@sentry/bun": "^10.47.0",
    "gray-matter": "^4",
    "hono": "^4.12.0",
    "prom-client": "^15",
    "tasknotes-types": "file:../tasknotes-types",
    "yaml": "^2",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@types/bun": "latest",
    "eslint": "^9.39.2",
    "jiti": "^2.6.1",
    "typescript": "^5.8",
    "typescript-eslint": "^8.53.1"
  }
}
