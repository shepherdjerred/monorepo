# AI Provider (anthropic | openai | google)
AI_PROVIDER=anthropic

# API Keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Model overrides (optional)
# CONVERSATION_MODEL=claude-sonnet-4-6-20260217
# REFLECTION_MODEL=claude-sonnet-4-6-20260217

# Voice (OpenAI Realtime, optional)
# REALTIME_MODEL=gpt-realtime-mini
# REALTIME_VOICE=ash

# Data directory (default: ~/.interview-practice)
# DATA_DIR=~/.interview-practice
