generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Subscription {
  id        Int    @id @default(autoincrement())
  playerId  Int
  channelId String
  player    Player @relation(fields: [playerId], references: [id])

  // JSON-serialized SubscriptionFilterSpec (@scout-for-lol/data); null = notify
  // all. Validated in the app via Zod; never queried in SQL.
  filters String?

  // Muted subscriptions stay intact (history, filters, channel wiring) but are
  // skipped when dispatching pre/post-match notifications.
  isMuted Boolean @default(false)

  // metadata
  serverId         String
  creatorDiscordId String
  createdTime      DateTime
  updatedTime      DateTime

  @@unique([serverId, playerId, channelId])
}

model Player {
  id                      Int                      @id @default(autoincrement())
  alias                   String
  discordId               String?
  accounts                Account[]
  subscriptions           Subscription[]
  competitionParticipants CompetitionParticipant[]
  competitionSnapshots    CompetitionSnapshot[]

  // metadata
  serverId         String
  creatorDiscordId String
  createdTime      DateTime
  updatedTime      DateTime

  @@unique([serverId, alias])
}

model Account {
  id       Int    @id @default(autoincrement())
  alias    String
  puuid    String
  region   String
  playerId Int
  player   Player @relation(fields: [playerId], references: [id])

  // Cached Riot ID (gameName#tagLine) resolved from the PUUID. Nullable
  // until first resolved; refreshed on read when older than 24h. Lets the
  // web UI show the real Riot ID instead of the user-chosen alias.
  riotGameName    String?
  riotTagLine     String?
  riotIdUpdatedAt DateTime?

  // Match processing tracking
  lastProcessedMatchId String? // Track last match we've processed to avoid duplicates
  lastMatchTime        DateTime? // Timestamp of the last match this player was in (for dynamic polling)
  lastCheckedAt        DateTime? // Timestamp of when we last checked for new matches (for polling intervals)

  // metadata
  serverId         String
  creatorDiscordId String
  createdTime      DateTime
  updatedTime      DateTime

  @@unique([serverId, puuid])
}

// Global, self-maintaining cache of known summoners (Riot IDs are public).
// Powers fast prefix autocomplete in the web "add player" flow. Populated on
// confirmed Riot resolutions + backfill from Account/PrematchParticipantFact;
// an entry is evicted when Riot can no longer resolve it (rename/deletion).
model SummonerIndex {
  id             Int      @id @default(autoincrement())
  puuid          String   @unique
  gameName       String
  tagLine        String
  region         String
  lastVerifiedAt DateTime
  createdTime    DateTime
  updatedTime    DateTime

  // Prefix-autocomplete on gameName (SQLite LIKE 'q%', ASCII case-insensitive).
  @@index([gameName])
}

model MatchRankHistory {
  id        Int    @id @default(autoincrement())
  matchId   String // Riot match ID
  puuid     String // Player PUUID
  queueType String // "solo" or "flex"

  // Rank snapshots (JSON serialized, nullable for unranked)
  rankBefore String? // JSON: {tier, division, lp, wins, losses}
  rankAfter  String? // JSON: {tier, division, lp, wins, losses}

  matchGameCreationAt DateTime? // Riot match info.gameCreation for historical attribution
  matchGameEndAt      DateTime? // Riot match info.gameEndTimestamp for rank ordering
  capturedAt          DateTime // When this was recorded

  @@unique([matchId, puuid, queueType])
  @@index([puuid, capturedAt])
  @@index([puuid, queueType, matchGameEndAt])
  @@index([matchId])
}

model StoredMatch {
  matchId               String    @id
  gameId                String
  platformId            String
  queueId               Int
  queue                 String?
  gameMode              String
  gameType              String
  gameVersion           String
  gameCreationAt        DateTime
  gameStartAt           DateTime?
  gameEndAt             DateTime
  durationSeconds       Int
  participantPuuidsJson String
  rawJson               String
  s3Key                 String?
  importedFromS3        Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([gameCreationAt])
  @@index([queueId, gameCreationAt])
  @@index([s3Key])
}

model StoredMatchTimeline {
  matchId        String   @id
  rawJson        String
  s3Key          String?
  importedFromS3 Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StoredPrematch {
  id                    Int       @id @default(autoincrement())
  dedupeKey             String    @unique
  gameId                String
  gameStartAt           DateTime?
  observedAt            DateTime
  platformId            String
  queueId               Int
  queue                 String?
  gameMode              String
  gameType              String
  participantPuuidsJson String
  rawJson               String
  s3Key                 String?
  importedFromS3        Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([observedAt])
  @@index([queueId, observedAt])
  @@index([s3Key])
}

model MatchParticipantFact {
  id                 Int      @id @default(autoincrement())
  serverId           String
  matchId            String
  gameId             String
  gameCreationAt     DateTime
  gameEndAt          DateTime
  queueId            Int
  queue              String?
  durationSeconds    Int
  playerId           Int
  accountId          Int?
  playerAlias        String
  discordId          String?
  puuid              String
  region             String?
  participantId      Int
  teamId             Int
  championId         Int
  championName       String
  win                Boolean
  surrendered        Boolean
  earlySurrendered   Boolean
  kills              Int
  deaths             Int
  assists            Int
  kda                Float
  creepScore         Int
  goldEarned         Int
  totalDamageDealt   Int
  damageToChampions  Int
  damageTaken        Int
  visionScore        Int
  rawParticipantJson String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([serverId, matchId, puuid])
  @@index([serverId, gameCreationAt])
  @@index([serverId, queueId, gameCreationAt])
  @@index([serverId, playerId, gameCreationAt])
  @@index([matchId])
}

model PrematchParticipantFact {
  id                 Int       @id @default(autoincrement())
  storedPrematchId   Int
  serverId           String
  gameId             String
  observedAt         DateTime
  gameStartAt        DateTime?
  queueId            Int
  queue              String?
  gameMode           String
  playerId           Int
  accountId          Int?
  playerAlias        String
  discordId          String?
  puuid              String
  region             String?
  teamId             Int
  playerSubteamId    Int?
  championId         Int
  riotId             String
  summonerName       String?
  selectedSkinIndex  Int
  rawParticipantJson String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([storedPrematchId, serverId, puuid])
  @@index([serverId, observedAt])
  @@index([serverId, queueId, observedAt])
  @@index([serverId, playerId, observedAt])
  @@index([gameId])
}

model ReportStoreImportProgress {
  source          String    @id
  importStatus    String
  lastKey         String?
  scannedObjects  Int       @default(0)
  importedObjects Int       @default(0)
  skippedObjects  Int       @default(0)
  failedObjects   Int       @default(0)
  startedAt       DateTime
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt
}

model ReportStoreImportFailure {
  id           Int      @id @default(autoincrement())
  source       String
  s3Key        String
  payloadType  String
  errorMessage String
  createdAt    DateTime @default(now())

  @@unique([source, s3Key, payloadType])
  @@index([source, createdAt])
}

model Report {
  id                  Int       @id @default(autoincrement())
  serverId            String
  ownerId             String
  channelId           String
  title               String
  description         String?
  queryText           String
  lookbackDays        Int       @default(30)
  maxRows             Int       @default(10)
  isEnabled           Boolean   @default(true)
  isSystemManaged     Boolean   @default(false)
  systemSource        String?
  sourceCompetitionId Int?
  cronExpression      String
  nextScheduledRunAt  DateTime?
  lastScheduledRunAt  DateTime?
  lastRunStatus       String?
  lastRunError        String?
  createdTime         DateTime
  updatedTime         DateTime

  runs ReportRun[]

  @@index([serverId, isEnabled])
  @@index([nextScheduledRunAt])
  @@index([sourceCompetitionId])
  @@index([systemSource])
}

model ReportRun {
  id           Int       @id @default(autoincrement())
  reportId     Int
  serverId     String
  trigger      String
  status       String
  startedAt    DateTime
  completedAt  DateTime?
  durationMs   Int?
  rowsReturned Int       @default(0)
  rowsScanned  Int       @default(0)
  errorMessage String?
  // Faithful per-run archive of what was posted: the rendered text body and an
  // S3 key for the chart PNG (null for text-only formats or when S3 is off).
  renderedContent String?
  imageS3Key      String?
  imageByteSize   Int?
  createdAt    DateTime  @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, startedAt])
  @@index([serverId, startedAt])
  @@index([status, startedAt])
}

// Season metadata seeded from packages/data/src/seasons.ts on every bot startup.
// Competition.seasonId is a FK to Season.id; date drift is resolved by re-seeding.
model Season {
  id           String        @id
  displayName  String
  startDate    DateTime
  endDate      DateTime
  competitions Competition[]
}

model Competition {
  id              Int     @id @default(autoincrement())
  serverId        String
  ownerId         String // Discord user ID
  title           String
  description     String
  channelId       String
  isCancelled     Boolean @default(false)
  visibility      String // OPEN, INVITE_ONLY, SERVER_WIDE
  criteriaType    String // Enum stored as string
  criteriaConfig  String // JSON stored as string
  maxParticipants Int     @default(50)

  // Time configuration (XOR: either fixed dates OR season)
  startDate DateTime?
  endDate   DateTime?
  seasonId  String?
  season    Season?   @relation(fields: [seasonId], references: [id])

  // Lifecycle tracking - when start/end processing was attempted
  // These prevent re-processing even if snapshot creation fails
  startProcessedAt           DateTime?
  endProcessedAt             DateTime?
  startNotifiedAt            DateTime?
  endNotifiedAt              DateTime?
  startNotificationMessageId String?
  endNotificationMessageId   String?

  // Leaderboard-post schedule (CRON expression evaluated in UTC).
  // NULL is treated as the legacy default '0 0 * * *' (daily midnight UTC).
  // Validated at write time to fire at most once per day.
  updateCronExpression  String?
  // Next time the dispatcher should post a leaderboard update for this row.
  // The dispatcher selects rows where this is <= now (or NULL, as self-heal)
  // and recomputes this field from updateCronExpression after each post.
  nextScheduledUpdateAt DateTime?
  // Wall-clock time of the most recent dispatched leaderboard post.
  lastScheduledUpdateAt DateTime?

  // Relations
  participants CompetitionParticipant[]
  snapshots    CompetitionSnapshot[]

  // Metadata
  creatorDiscordId String
  createdTime      DateTime
  updatedTime      DateTime

  // Note: We do NOT have a unique constraint on [serverId, ownerId]
  // This allows users to create multiple competitions over time
  // The "one active competition per owner" rule is enforced in application logic
  @@index([serverId, isCancelled])
  @@index([serverId, ownerId, isCancelled])
  @@index([nextScheduledUpdateAt])
}

model CompetitionParticipant {
  id            Int       @id @default(autoincrement())
  competitionId Int
  playerId      Int
  status        String // INVITED, JOINED, LEFT
  invitedBy     String? // Discord user ID (nullable)
  invitedAt     DateTime? // When invited (nullable - null if joined directly)
  joinedAt      DateTime? // When joined (nullable - null if only invited)
  leftAt        DateTime? // When left (nullable - null if still participating)

  // Relations
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  player      Player      @relation(fields: [playerId], references: [id])

  @@unique([competitionId, playerId])
  @@index([competitionId, status])
}

model CompetitionSnapshot {
  id            Int      @id @default(autoincrement())
  competitionId Int
  playerId      Int
  snapshotType  String // START, END
  snapshotData  String // JSON stored as string
  snapshotTime  DateTime

  // Relations
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  player      Player      @relation(fields: [playerId], references: [id])

  @@unique([competitionId, playerId, snapshotType])
}

model ServerPermission {
  id            Int      @id @default(autoincrement())
  serverId      String
  discordUserId String
  permission    String // CREATE_COMPETITION (can add more later)
  grantedBy     String // Discord user ID
  grantedAt     DateTime

  @@unique([serverId, discordUserId, permission])
}

model GuildPermissionError {
  id                    Int       @id @default(autoincrement())
  serverId              String
  channelId             String
  errorType             String // Type of permission error
  errorReason           String? // Detailed reason
  firstOccurrence       DateTime // When this error first occurred
  lastOccurrence        DateTime // Most recent occurrence
  consecutiveErrorCount Int       @default(1) // Number of consecutive errors
  lastSuccessfulSend    DateTime? // Last time a message was successfully sent to this server
  ownerNotified         Boolean   @default(false) // DEPRECATED (was the abandoned-guild latch); unused since notificationStage replaced it
  // Backed-off owner notification escalation for the current failure streak.
  // notificationStage: 0 = none sent, 1 = immediate sent, 2 = +1w sent, 3 = +1mo sent (terminal).
  // lastNotifiedAt anchors the next stage's delay (NOT firstOccurrence) so existing
  // mid-streak rows restart cleanly at "immediate" instead of jumping to "month".
  notificationStage     Int       @default(0)
  lastNotifiedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([serverId, channelId])
  @@index([serverId, consecutiveErrorCount])
  @@index([lastOccurrence])
}

// Central audit log of every direct message (DM) the bot sends to a user.
// All DMs MUST flow through `sendDM` (discord/utils/dm.ts), which writes one
// row here per attempt so DMs are fully traceable. Append-only.
model DmAuditLog {
  id           Int      @id @default(autoincrement())
  recipientId  String // Discord user (snowflake) the DM was addressed to
  recipientTag String? // Discord tag at send time, when resolvable
  guildId      String? // Guild this DM relates to, when applicable
  kind           String // Category, e.g. "permission_error" | "abandonment" | "feedback_request" | "competition_invite" | "prune_notice"
  content        String // The message body that was (attempted to be) sent
  deliveryStatus String // "sent" | "dm_disabled" | "failed"
  errorMessage   String? // Failure detail when delivery != "sent"
  createdAt    DateTime @default(now())

  @@index([recipientId, createdAt])
  @@index([kind, createdAt])
  @@index([guildId, createdAt])
}

// =============================================================================
// Desktop Voice Notification System
// =============================================================================

model User {
  discordId           String    @id // Discord snowflake ID
  discordUsername     String
  discordAvatar       String?
  discordAccessToken  String?
  discordRefreshToken String?
  tokenExpiresAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  apiTokens      ApiToken[]
  soundPacks     SoundPack[]
  desktopClients DesktopClient[]
  storedSounds   StoredSound[]
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [discordId], onDelete: Cascade)
  token      String    @unique // hashed token
  name       String
  scopes     String    @default("events:write")
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

model DesktopClient {
  id                Int        @id @default(autoincrement())
  userId            String
  user              User       @relation(fields: [userId], references: [discordId], onDelete: Cascade)
  clientId          String     @unique // UUID generated on first connection
  hostname          String?
  isConnected       Boolean    @default(false)
  lastHeartbeat     DateTime?
  currentGameId     String? // Game ID if in active game
  voiceChannelId    String? // Discord voice channel to join
  guildId           String? // Discord guild ID for voice
  activeSoundPackId Int?
  activeSoundPack   SoundPack? @relation(fields: [activeSoundPackId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([userId])
}

model SoundPack {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [discordId], onDelete: Cascade)
  name        String
  version     String   @default("1.0.0")
  description String?
  isPublic    Boolean  @default(false) // Whether other users can use this pack
  settings    String // JSON: { masterVolume: number, normalization: boolean }
  defaults    String // JSON: { gameStart?: SoundPool, kill?: SoundPool, ... }
  rules       String // JSON: SoundRule[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  desktopClients DesktopClient[]

  @@unique([userId, name])
  @@index([userId])
  @@index([isPublic])
}

model StoredSound {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [discordId], onDelete: Cascade)
  s3Key        String   @unique // S3/R2 object key
  originalName String // Original filename
  mimeType     String
  sizeBytes    Int
  durationMs   Int?
  sourceType   String // "upload", "youtube", "url"
  sourceUrl    String? // Original URL if from YouTube/URL
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([sourceUrl])
}

model GuildInstall {
  id                Int       @id @default(autoincrement())
  serverId          String    @unique
  serverName        String
  ownerDiscordId    String
  addedByDiscordId  String // Installer (from audit log), fallback to ownerId
  memberCount       Int
  installedAt       DateTime
  outreach3dSentAt  DateTime? // null = not yet sent
  outreach14dSentAt DateTime? // null = not yet sent
  outreach30dSentAt DateTime? // 30-day "still not configured" nudge; null = not yet sent

  @@index([installedAt])
}

model BotState {
  id                   Int       @id @default(1)
  lastSuccessfulPollAt DateTime?
  updatedAt            DateTime  @updatedAt
}

model ActiveGame {
  id            Int      @id @default(autoincrement())
  gameId        BigInt   @unique // Riot game ID (from Spectator V5 API)
  trackedPuuids String // JSON array of tracked puuids detected in this game
  detectedAt    DateTime // When we first detected this game
  expiresAt     DateTime // TTL: auto-cleanup after this time (detectedAt + 2 hours)
  updatedAt     DateTime @updatedAt

  @@index([expiresAt])
}

model GameEventLog {
  id          Int      @id @default(autoincrement())
  userId      String
  clientId    String
  eventType   String // "kill", "multikill", "objective", etc.
  eventData   String // JSON of event context
  soundPlayed String? // Sound ID that was played
  timestamp   DateTime @default(now())

  @@index([userId, timestamp])
  @@index([clientId, timestamp])
}

// Records every match for which the AI review pipeline has been entered.
// Insert happens BEFORE the first OpenAI call so that even a mid-pipeline
// crash leaves a row behind, preventing duplicate spend on the next poll.
// Pure dedup table — one row per match, never reprocessed.
model MatchAiAttempt {
  matchId     String   @id // Riot match ID, e.g. EUW1_7843083474
  attemptedAt DateTime @default(now())
}

// A guild the reconcile-removed-guilds sweep saw missing from the client
// cache AND unconfirmed by a live `guilds.fetch` (Discord 10004) on some
// previous day's run. Cleanup only proceeds once a candidate has been
// re-observed as missing on a LATER calendar day than `firstDetectedAt` -
// a single day's outage (Discord region/shard down, cache hydration gap)
// resolves well within 24h, while a real removal stays missing across runs.
// The row is deleted as soon as a run finds the guild reachable again
// (recovered) or after cleanup runs (confirmed and handled).
model GuildRemovalCandidate {
  serverId        String   @id
  firstDetectedAt DateTime
  lastCheckedAt   DateTime
}

// Web-UI initiated subscription changes. Every mutation through the web UI
// records a row so we can audit who added/removed what from outside Discord.
model AuditLog {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  actorDiscordId  String
  serverId        String
  action          String   // AuditAction enum value
  targetChannelId String?
  targetPlayerId  Int?
  targetAccountId Int?
  payload         String   // JSON-encoded before/after snapshot
  ipAddress       String?
  userAgent       String?

  @@index([serverId, createdAt])
  @@index([actorDiscordId, createdAt])
}
