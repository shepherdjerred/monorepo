load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/bazel:typecheck.bzl", "typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files([
    "package.json",
    "docker-config.toml.example",
])

# .gitkeep ensures the dist/ directory exists in the source tree for
# include_dir! in Rust compilation. Force-added to git despite .gitignore.
exports_files(
    ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "dist_gitkeep",
    srcs = ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

# Astro/Starlight docs site; this js_library wraps sources for dependency tracking.
js_library(
    name = "pkg",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
            "src/**/*.astro",
            "src/**/*.mdx",
            "src/**/*.md",
        ],
        allow_empty = True,
    ) + ["package.json"],
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@astrojs/starlight",
        ":node_modules/astro",
    ],
)

eslint_test(
    name = "lint",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
        ],
        allow_empty = True,
    ),
)

typecheck_test(
    name = "typecheck",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
        ],
        allow_empty = True,
    ),
    deps = [":pkg"],
)
