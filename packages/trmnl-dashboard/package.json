{
  "name": "@shepherdjerred/trmnl-dashboard",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "bunx eslint . --max-warnings=0",
    "docker:build": "docker buildx build --cache-from type=registry,ref=ghcr.io/shepherdjerred/trmnl-dashboard:buildcache ${DOCKER_BUILD_EXTRA_ARGS:-} --load -t trmnl-dashboard:dev -f Dockerfile ../..",
    "smoke": "bun scripts/smoke.ts"
  },
  "dependencies": {
    "@sentry/bun": "^10.49.0",
    "@shepherdjerred/home-assistant": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "workspace:*",
    "@types/bun": "^1.3.13",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3"
  }
}
