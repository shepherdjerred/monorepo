{
  "extends": [
    "@tsconfig/strictest/tsconfig.json",
    "@tsconfig/node-lts/tsconfig.json",
    "@tsconfig/recommended/tsconfig.json"
  ],
  "compilerOptions": {
    "types": ["@types/bun"],
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "noEmit": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true
  }
}
