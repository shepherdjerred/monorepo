{
  "compilerOptions": {
    "target": "ES2022",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@dagger.io/dagger": ["./sdk/index.ts"],
      "@dagger.io/dagger/telemetry": ["./sdk/telemetry.ts"]
    }
  },
  "exclude": ["node_modules", "eslint.config.ts"]
}
