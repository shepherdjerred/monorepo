load("@aspect_bazel_lib//lib:expand_template.bzl", "expand_template")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("@rules_oci//oci:defs.bzl", "oci_image", "oci_push")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/oci:bun_service_image.bzl", "bun_service_image")
load("//tools/rules_bun/bun:defs.bzl", "bun_library")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# Home Assistant automations — runs directly with Bun.
bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@digital-alchemy/automation",
        ":node_modules/@digital-alchemy/core",
        ":node_modules/@digital-alchemy/hass",
        ":node_modules/@digital-alchemy/synapse",
        ":node_modules/@digital-alchemy/type-writer",
        ":node_modules/@sentry/bun",
        ":node_modules/@total-typescript/ts-reset",
        ":node_modules/openai",
        ":node_modules/prom-client",
        ":node_modules/remeda",
        ":node_modules/simple-git",
        ":node_modules/ts-pattern",
        ":node_modules/zod",
    ],
)

eslint_test(
    name = "lint",
    size = "small",
    srcs = glob(["src/**/*.ts"]),
)

# Requires @digital-alchemy/type-writer generated entity types from a running
# Home Assistant instance. Type checking works locally but not in Bazel sandbox.
bun_typecheck_test(
    name = "typecheck",
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    extra_files = ["//:tsconfig.base.json"],
    deps = [
        ":pkg",
        "//:node_modules/typescript",
        "//:node_modules/@types/bun",
        "//:node_modules/undici-types",
    ],
)

# Container image for K8s deployment.
# Two-stage: bun_service_image creates the base, then we add git on top
# (simple-git needs the git CLI at runtime).
bun_service_image(
    name = "image_base",
    srcs = glob(["src/**/*.ts"]) + ["package.json"],
    entry_point = "src/main.ts",
    env = {"NODE_ENV": "production"},
    exposed_ports = ["9090"],
    labels = {
        "org.opencontainers.image.title": "homelab",
        "org.opencontainers.image.description": "Home Assistant automations",
        "org.opencontainers.image.source": "https://github.com/shepherdjerred/monorepo",
    },
    package_json = "package.json",
    visibility = ["//visibility:public"],
    workspace_packages = {
        "packages/homelab/src/cdk8s": "//packages/homelab/src/cdk8s:pkg",
        "packages/homelab/src/helm-types": "//packages/homelab/src/helm-types:pkg",
        "packages/homelab/src/deps-email": "//packages/homelab/src/deps-email:pkg",
    },
)

oci_image(
    name = "image",
    base = ":image_base",
    tars = ["//tools/oci:git_layer"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "image_tags_tmpl",
    outs = ["image_tags_tmpl.txt"],
    cmd = "echo '{STABLE_GIT_SHA}' > $@",
    tags = ["manual"],
)

expand_template(
    name = "image_tags",
    out = "image_tags.txt",
    template = ":image_tags_tmpl",
    stamp_substitutions = {"{STABLE_GIT_SHA}": "{{STABLE_GIT_SHA}}"},
    tags = ["manual"],
)

oci_push(
    name = "image_push",
    image = ":image",
    repository = "ghcr.io/shepherdjerred/homelab",
    remote_tags = ":image_tags",
    tags = ["manual"],
    visibility = ["//visibility:public"],
)
