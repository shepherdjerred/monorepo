load("@aspect_rules_js//js:defs.bzl", "js_binary", "js_library")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:bun_test.bzl", "bun_test")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/bazel:prisma.bzl", "prisma_generate")
load("//tools/bazel:typecheck.bzl", "typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

filegroup(
    name = "testdata",
    srcs = glob(["src/league/model/__tests__/testdata/**"]),
    visibility = ["//packages/scout-for-lol/packages/data:__pkg__"],
)

# Prisma client generation (run explicitly: bazel build //packages/scout-for-lol/packages/backend:prisma_generate)
prisma_generate(
    name = "prisma_generate",
    schema = "prisma/schema.prisma",
)

js_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]) + ["package.json"],
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@aws-sdk/client-s3",
        ":node_modules/@discordjs/voice",
        ":node_modules/@google/generative-ai",
        ":node_modules/@prisma/client",
        ":node_modules/@sentry/bun",
        ":node_modules/@trpc/server",
        ":node_modules/cron",
        ":node_modules/date-fns",
        ":node_modules/discord.js",
        ":node_modules/dotenv",
        ":node_modules/env-var",
        ":node_modules/openai",
        ":node_modules/prism-media",
        ":node_modules/prisma",
        ":node_modules/prom-client",
        ":node_modules/react",
        ":node_modules/remeda",
        ":node_modules/sodium-native",
        ":node_modules/ts-pattern",
        ":node_modules/tslog",
        ":node_modules/twisted",
        ":node_modules/uuid",
        ":node_modules/yoga-wasm-web",
        ":node_modules/zod",
        ":node_modules/zod-validation-error",
        "//packages/scout-for-lol/packages/data:pkg",
        "//packages/scout-for-lol/packages/report:pkg",
    ],
)

js_binary(
    name = "backend",
    data = [":pkg"],
    entry_point = "src/index.ts",
)

eslint_test(
    name = "lint",
    srcs = glob(["src/**/*.ts"]),
    config = "//packages/scout-for-lol:eslint.config.ts",
)

# Blocked: workspace packages (@scout-for-lol/data, @scout-for-lol/report) + #generated/prisma/client
# not resolved by tsc in sandbox.
typecheck_test(
    name = "typecheck",
    srcs = glob(["src/**/*.ts"]),
    data = ["package.json"],
    extends = "//packages/scout-for-lol:tsconfig_base",
    tags = ["manual"],
    deps = [
        ":node_modules/@aws-sdk/client-s3",
        ":node_modules/@discordjs/voice",
        ":node_modules/@google/generative-ai",
        ":node_modules/@prisma/client",
        ":node_modules/@scout-for-lol/data",
        ":node_modules/@scout-for-lol/report",
        ":node_modules/@sentry/bun",
        ":node_modules/@trpc/server",
        ":node_modules/bun-types",
        ":node_modules/cron",
        ":node_modules/date-fns",
        ":node_modules/discord.js",
        ":node_modules/dotenv",
        ":node_modules/env-var",
        ":node_modules/openai",
        ":node_modules/prism-media",
        ":node_modules/prisma",
        ":node_modules/prom-client",
        ":node_modules/react",
        ":node_modules/remeda",
        ":node_modules/sodium-native",
        ":node_modules/ts-pattern",
        ":node_modules/tslog",
        ":node_modules/twisted",
        ":node_modules/uuid",
        ":node_modules/yoga-wasm-web",
        ":node_modules/zod",
        ":node_modules/zod-validation-error",
        "//:node_modules/@types/bun",
        "//:node_modules/@types/node",
        "//:node_modules/undici-types",
        "//packages/scout-for-lol/packages/data:pkg",
        "//packages/scout-for-lol/packages/report:pkg",
    ],
)

# Blocked: tests use #generated/prisma/client (custom output path) which
# requires prisma generate with output to ./generated/prisma/client/ plus
# workspace packages (@scout-for-lol/data, @scout-for-lol/report).
bun_test(
    name = "test",
    size = "large",
    srcs = glob(["src/**/*.ts"]),
    tags = ["manual"],
    deps = [
        ":node_modules/@aws-sdk/client-s3",
        ":node_modules/@discordjs/voice",
        ":node_modules/@google/generative-ai",
        ":node_modules/@prisma/client",
        ":node_modules/@sentry/bun",
        ":node_modules/@trpc/server",
        ":node_modules/cron",
        ":node_modules/date-fns",
        ":node_modules/discord.js",
        ":node_modules/dotenv",
        ":node_modules/env-var",
        ":node_modules/openai",
        ":node_modules/prism-media",
        ":node_modules/prisma",
        ":node_modules/prom-client",
        ":node_modules/react",
        ":node_modules/remeda",
        ":node_modules/sodium-native",
        ":node_modules/ts-pattern",
        ":node_modules/tslog",
        ":node_modules/twisted",
        ":node_modules/uuid",
        ":node_modules/yoga-wasm-web",
        ":node_modules/zod",
        ":node_modules/zod-validation-error",
        "//:node_modules/@types/bun",
        "//packages/scout-for-lol/packages/data:pkg",
        "//packages/scout-for-lol/packages/report:pkg",
    ],
)
