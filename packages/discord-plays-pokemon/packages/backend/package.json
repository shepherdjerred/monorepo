{
  "name": "@discord-plays-pokemon/backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "watch": "bunx tsc --watch",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "lint": "bun run lint:check",
    "lint:fix": "bun run lint:eslint:fix",
    "lint:check": "bun run lint:eslint:check",
    "lint:eslint:check": "bunx eslint .",
    "lint:eslint:fix": "bunx eslint . --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "e2e:goal": "bun test src/goal/e2e-goal.integration.test.ts"
  },
  "dependencies": {
    "@discord-plays-pokemon/common": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@shepherdjerred/discord-stream-lifecycle": "workspace:*",
    "@shepherdjerred/discord-video-stream": "workspace:*",
    "@shepherdjerred/llm-models": "workspace:*",
    "@shepherdjerred/llm-observability": "workspace:*",
    "discord.js": "^14.26.4",
    "discord.js-selfbot-v13": "^3.6.1",
    "express": "^5.0.0",
    "lodash": "4.18.1",
    "prom-client": "^15.1.3",
    "rxjs": "^7.8.2",
    "smol-toml": "1.6.1",
    "socket.io": "^4.8.1",
    "ts-pattern": "^5.7.0",
    "winston": "^3.17.0",
    "xstate": "^5.32.4",
    "zod": "^4.4.3",
    "@shepherdjerred/discord-plays-core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shepherdjerred/eslint-config": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/express": "^5.0.1",
    "@types/lodash": "^4.17.16",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.50.0"
  }
}
