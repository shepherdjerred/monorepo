load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/bazel:vite_build.bzl", "vite_build")
load("//tools/rules_bun/bun:defs.bzl", "bun_library", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# .gitkeep ensures the dist/ directory exists in the source tree for
# include_dir! in Rust compilation. Force-added to git despite .gitignore.
exports_files(
    ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "dist_gitkeep",
    srcs = ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

vite_build(name = "vite_build")

# Vite/React SPA; this bun_library wraps sources for dependency tracking.
bun_library(
    name = "pkg",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
    ]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/react",
        ":node_modules/react-dom",
        ":node_modules/zod",
        "//packages/clauderon/web/client:pkg",
        "//packages/clauderon/web/shared:pkg",
    ],
)

eslint_test(
    name = "lint",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
    ]),
)

bun_typecheck_test(
    name = "typecheck",
    extra_files = ["//:tsconfig.base.json"],
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
        ":node_modules/@types/bun",
        ":node_modules/typescript",
        ":node_modules/vite",
    ],
)

bun_test(
    name = "test",
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
    ],
)
