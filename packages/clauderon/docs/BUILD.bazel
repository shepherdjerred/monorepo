load("@bun_modules//:defs.bzl", "bun_link_all_packages")
load("//tools/rules_bun/bun:defs.bzl", "bun_astro_build", "bun_astro_check", "bun_eslint_test", "bun_library", "bun_prepared_tree")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

bun_link_all_packages(name = "node_modules")

exports_files([
    "package.json",
    "docker-config.toml.example",
])

# .gitkeep ensures the dist/ directory exists in the source tree for
# include_dir! in Rust compilation. Force-added to git despite .gitignore.
exports_files(
    ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "dist_gitkeep",
    srcs = ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

# Manual: Starlight CSS virtual module path resolution fails in sandbox — Vite can't find
# compile metadata for .astro component styles because node_modules hardlinks resolve back
# to the deep execroot TreeArtifact path instead of the /tmp overlay
bun_astro_build(
    name = "astro_build",
    data = glob([
        "public/**",
        "src/content/**",
        "src/assets/**",
    ]),
    extra_files = [
        "astro.config.mjs",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    tags = ["manual"],
    deps = [":pkg"],
)

bun_astro_check(
    name = "astro_check",
    extra_files = [
        "astro.config.mjs",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    deps = [":pkg"],
)

# Astro/Starlight docs site; this bun_library wraps sources for dependency tracking.
bun_library(
    name = "pkg",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
        ],
        allow_empty = True,
    ),
    data = glob(
        [
            "src/**/*.astro",
            "src/**/*.mdx",
            "src/**/*.md",
        ],
        allow_empty = True,
    ),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@astrojs/starlight",
        ":node_modules/astro",
    ],
)

bun_prepared_tree(
    name = "tree",
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    node_modules = ":node_modules",
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/typescript",
        "//packages/eslint-config:pkg",
    ],
)

bun_eslint_test(
    name = "lint",
    prepared_tree = ":tree",
)

# Astro uses virtual modules (astro:content) only resolvable in its build pipeline.
# Type checking is done via `astro check` in local dev; tsc can't resolve these.
bun_typecheck_test(
    name = "typecheck",
    prepared_tree = ":tree",
    tags = ["manual"],
)
