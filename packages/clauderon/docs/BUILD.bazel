load("@bun_modules//:defs.bzl", "bun_link_all_packages")
load("//tools/bazel:astro_build.bzl", "astro_build")
load("//tools/bazel:astro_check.bzl", "astro_check")
load("//tools/rules_bun/bun:defs.bzl", "bun_eslint_test", "bun_library")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

bun_link_all_packages(name = "node_modules")

exports_files([
    "package.json",
    "docker-config.toml.example",
])

# .gitkeep ensures the dist/ directory exists in the source tree for
# include_dir! in Rust compilation. Force-added to git despite .gitignore.
exports_files(
    ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "dist_gitkeep",
    srcs = ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

astro_build(name = "astro_build")

astro_check(name = "astro_check")

# Astro/Starlight docs site; this bun_library wraps sources for dependency tracking.
bun_library(
    name = "pkg",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
        ],
        allow_empty = True,
    ),
    data = glob(
        [
            "src/**/*.astro",
            "src/**/*.mdx",
            "src/**/*.md",
        ],
        allow_empty = True,
    ),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@astrojs/starlight",
        ":node_modules/astro",
    ],
)

bun_eslint_test(
    name = "lint",
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    node_modules = ":node_modules",
    deps = [
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/typescript",
        "//packages/eslint-config:pkg",
    ],
)

# Astro uses virtual modules (astro:content) only resolvable in its build pipeline.
# Type checking is done via `astro check` in local dev; tsc can't resolve these.
bun_typecheck_test(
    name = "typecheck",
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
        "//:node_modules/typescript",
    ],
)
