{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    // The Playwright CI container sets PLAYWRIGHT_BROWSERS_PATH; without the
    // pass-through, turbo's strict env hides it and the browser launch falls
    // back to ~/.cache/ms-playwright (empty in the container). passThroughEnv
    // (not env) because the path is machine-specific and must not shift the
    // task hash.
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_BROWSERS_PATH"]
    }
  }
}
