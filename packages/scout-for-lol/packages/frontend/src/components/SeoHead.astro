---
// Shared SEO/head partial used by every layout (marketing Layout, app AppLayout,
// and the review-tool layout). It emits ONLY meta/link/script tags — no visual
// tokens — so it is safe to share across the marketing and app design surfaces.
//
// Every built page must emit og:title/og:url/og:type/og:image because the
// astro-opengraph-images integration's extract() step reads those tags (and
// throws if they are missing) before generating the per-page OG image.
//
// The generated OG image path is deterministic and mirrors the package's own
// `getImagePath`: a directory route (pathname ending in `/`) maps to
// `<route>/index.png`. We compute it inline rather than importing the package
// barrel, which would bundle the whole Satori/jsdom integration into every
// page's SSR chunk.
interface Props {
  title: string;
  description: string;
  /** Root-relative or absolute override for the share image. Defaults to the
   *  per-page image generated by astro-opengraph-images. */
  image?: string | undefined;
  /** Emit robots noindex + skip JSON-LD (dashboard / dev tooling pages). */
  noindex?: boolean | undefined;
}

const { title, description, image, noindex = false } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const generatedOgPath = Astro.url.pathname.endsWith("/")
  ? `${Astro.url.pathname}index.png`
  : `${Astro.url.pathname}.png`;
const ogImage = new URL(image ?? generatedOgPath, Astro.site).toString();

const siteName = "Scout for League of Legends";

// Fixed, application-level description for the SoftwareApplication schema.
// The per-page `description` prop describes the individual page, not the app,
// so it must NOT be reused here — every page would otherwise advertise a
// different application description and scrapers would cache an arbitrary one.
const appDescription =
  "Get notified when your friends start League of Legends matches and get beautiful post-match reports delivered right to your Discord server.";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: siteName,
  description: appDescription,
  url: Astro.site?.toString(),
  applicationCategory: "GameApplication",
  operatingSystem: "Discord",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};
---

{/* Global metadata */}
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#4f46e5" />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Icons */}
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

{/* Canonical */}
<link rel="canonical" href={canonicalUrl} />

{/* Primary meta tags */}
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

{/* Open Graph */}
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={siteName} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{/* Structured data (marketing pages only) */}
{
  !noindex && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  )
}
