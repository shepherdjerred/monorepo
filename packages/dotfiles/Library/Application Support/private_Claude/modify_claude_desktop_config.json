{{- /* chezmoi:modify-template */ -}}
{{- $data := dict -}}
{{- if ne .chezmoi.stdin "" -}}
{{-   $data = fromJson .chezmoi.stdin -}}
{{- end -}}
{{ $data |
  setValueAtPath "mcpServers" (includeTemplate "claude-mcp-servers.json.tmpl" . | fromJson) |
  setValueAtPath "preferences.coworkScheduledTasksEnabled" false |
  setValueAtPath "preferences.sidebarMode" "task" |
  toPrettyJson -}}
