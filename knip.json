{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "scripts": {
      "entry": ["*.ts", "observability/**/*.ts"],
      "project": ["**/*.ts"]
    },
    "packages/birmel": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/docs-board": {
      "entry": [
        "src/client/main.tsx",
        "src/server/index.ts",
        "src/dev.ts",
        "src/cli/*.ts",
        "vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "vite.config.ts"]
    },
    "packages/discord-plays-core": {
      "entry": ["src/index.ts", "src/entry.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/eslint-config": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["eslint-import-resolver-node"]
    },
    "packages/astro-opengraph-images": {
      "entry": ["src/index.ts", "src/presets/render-examples.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/better-skill-capped": {
      "entry": ["src/index.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "vite": false
    },
    "packages/sjer.red": {
      "entry": ["src/**/*.astro", "astro.config.ts"],
      "project": ["src/**/*.{ts,tsx,astro}"]
    },
    "packages/webring": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/home-assistant": {
      "entry": ["src/index.ts", "src/codegen/cli.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/llm-models": {
      "entry": ["src/index.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/llm-observability": {
      "entry": ["src/index.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/starlight-karma-bot": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/homelab/src/cdk8s": {
      "entry": ["src/app.ts", "src/**/*.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/homelab/src/helm-types": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/discord-plays-pokemon/packages/backend": {
      "entry": [
        "src/index.ts",
        "src/**/*.test.ts",
        "scripts/**/*.ts",
        "src/goal/pokemonctl.ts"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/discord-plays-pokemon/packages/common": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/discord-plays-pokemon/packages/frontend": {
      "entry": [
        "src/main.tsx",
        "src/**/*.test.ts",
        "src/stories/**/*.tsx",
        "vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "*.ts"]
    },
    "packages/discord-plays-pokemon": {
      "entry": ["scripts/**/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "packages/discord-plays-mario-kart": {
      "entry": ["scripts/**/*.ts", "wasm-src/**/*.mjs"],
      "project": ["scripts/**/*.ts", "wasm-src/**/*.mjs"]
    },
    "packages/discord-plays-mario-kart/packages/backend": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/discord-plays-mario-kart/packages/common": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/discord-plays-mario-kart/packages/frontend": {
      "entry": [
        "src/main.tsx",
        "src/**/*.test.ts",
        "src/stories/**/*.tsx",
        "vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "*.ts"]
    },
    "packages/scout-for-lol/packages/backend": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/scout-for-lol/packages/data": {
      "entry": ["src/index.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/scout-for-lol/packages/report": {
      "entry": ["src/index.ts", "build.ts"],
      "project": ["src/**/*.{ts,tsx}", "*.ts"]
    },
    "packages/scout-for-lol/packages/frontend": {
      "entry": ["astro.config.ts", "src/**/*.tsx", "src/*-stub.ts"],
      "project": ["src/**/*.{ts,tsx,astro}", "*.ts"]
    },
    "packages/scout-for-lol/packages/app": {
      "entry": [
        "src/main.tsx",
        "src/**/*.test.ts",
        "vite.config.ts",
        "index.html",
        "public/**/*.js"
      ],
      "project": ["src/**/*.{ts,tsx}", "*.ts", "public/**/*.js"]
    },
    "packages/scout-for-lol/packages/desktop": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "vite": false,
      "postcss": false
    },
    "packages/scout-for-lol/packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/scout-for-lol": {
      "entry": ["scripts/**/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "packages/cooklang-rich-preview": {
      "entry": ["astro.config.mjs", "src/**/*.astro"],
      "project": ["src/**/*.{ts,tsx,astro}", "*.ts"]
    },
    "packages/monarch": {
      "entry": [
        "src/index.ts",
        "src/**/*.test.ts",
        "src/lib/*/classify.ts",
        "scripts/**/*.ts"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/stocks-sjer-red": {
      "entry": ["astro.config.ts", "src/**/*.astro"],
      "project": ["src/**/*.{ts,astro}", "*.ts"]
    },
    "packages/streambot": {
      "entry": [
        "src/index.ts",
        "test/**/*.ts",
        "integration/**/*.ts",
        "e2e/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts",
        "integration/**/*.ts",
        "e2e/**/*.ts"
      ]
    },
    "packages/temporal": {
      "entry": [
        "src/worker.ts",
        "src/client.ts",
        "src/**/*.test.ts",
        "scripts/**/*.ts"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/trmnl-dashboard": {
      "entry": ["src/index.ts", "src/__tests__/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/leetcode": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/toolkit": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/tasknotes-server": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/tasknotes-types": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/homelab": {
      "entry": ["scripts/**/*.ts", "eslint.config.ts"],
      "project": ["scripts/**/*.ts", "eslint.config.ts"]
    },
    "packages/discord-stream-lifecycle": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "exports": "error",
    "optionalPeerDependencies": "error",
    "catalog": "error",
    "duplicates": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "namespaceMembers": "off",
    "unresolved": "error",
    "unlisted": "error",
    "binaries": "error"
  },
  "ignoreUnresolved": [
    "^#generated/ha-schema\\.ts$",
    "^#generated/prisma/",
    "^~icons/"
  ],
  "ignore": [
    "**/eslint.config.ts",
    "**/postcss.config.ts",
    "**/generated/**",
    "**/dist/**",
    "archive/**",
    "practice/**",
    "packages/discord-video-stream/**",
    "packages/resume/**",
    "packages/dotfiles/**",
    "packages/fonts/**",
    "packages/anki/**",
    "packages/webring/example/**",
    "packages/cooklang-for-obsidian/**",
    "packages/tasks-for-obsidian/**",
    "packages/bun-decompile/**",
    "packages/docs/**",
    "poc/**",
    "scripts/observability/local-stack/**"
  ],
