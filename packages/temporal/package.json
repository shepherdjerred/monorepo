{
  "name": "@shepherdjerred/temporal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#shared/*": "./src/shared/*",
    "#activities/*": "./src/activities/*",
    "#workflows/*": "./src/workflows/*",
    "#generated/*": "./src/generated/*"
  },
  "scripts": {
    "start": "bun run src/worker.ts",
    "build": "bun run scripts/ensure-ha-schema.ts && tsc",
    "typecheck": "bun run scripts/ensure-ha-schema.ts && bunx tsc --noEmit",
    "lint": "bunx eslint --cache .",
    "test": "bun run scripts/ensure-ha-schema.ts && bun test src/activities",
    "test:integration": "bun run scripts/ensure-ha-schema.ts && bun test src/integration.test.ts",
    "generate": "bun ../home-assistant/src/codegen/cli.ts --out src/generated/ha-schema.ts --name HaSchema"
  },
  "dependencies": {
    "@shepherdjerred/home-assistant": "file:../home-assistant",
    "firebase": "^12.12.1",
    "@kubernetes/client-node": "^1.4.0",
    "@sentry/bun": "^10.49.0",
    "@temporalio/activity": "^1.16.1",
    "@temporalio/client": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "openai": "^6.34.0",
    "simple-git": "^3.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/recommended": "^1.0.13",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.12",
    "eslint": "^9.39.4",
    "jiti": "^2.6.1",
    "typescript": "^6.0.3"
  }
}
