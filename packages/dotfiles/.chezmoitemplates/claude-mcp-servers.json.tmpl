{{- /* Define OS-specific paths */ -}}
{{- $bunxCmd := "bunx" -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $bunxCmd = printf "%s/.local/share/mise/shims/bunx" .chezmoi.homeDir -}}
{{- else if eq .chezmoi.os "windows" -}}
  {{- $bunxCmd = "bunx" -}}
{{- end -}}
{
  "playwright": {
    "type": "stdio",
    "command": {{ $bunxCmd | quote }},
    "args": ["-y", "@playwright/mcp"],
    "env": {}
  },
  "canvas": {
    "command": "npx",
    "args": [
      "-y",
      "mcp-remote",
      "https://mcp-gateway.tailnet-1a49.ts.net/canvas/sse"
    ]
  },
  "todoist": {
    "command": "npx",
    "args": [
      "-y",
      "mcp-remote",
      "https://mcp-gateway.tailnet-1a49.ts.net/todoist/sse"
    ]
  },
  "piazza": {
    "command": "npx",
    "args": [
      "-y",
      "mcp-remote",
      "https://mcp-gateway.tailnet-1a49.ts.net/piazza/sse"
    ]
  }
}