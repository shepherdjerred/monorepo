load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/rules_bun/bun:defs.bzl", "bun_binary", "bun_library", "bun_prisma_generate", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

filegroup(
    name = "testdata",
    srcs = glob(["src/league/model/__tests__/testdata/**"]),
    visibility = ["//packages/scout-for-lol/packages/data:__pkg__"],
)

# Prisma client generation (run explicitly: bazel build //packages/scout-for-lol/packages/backend:prisma_generate)
bun_prisma_generate(
    name = "prisma_generate",
    schema = "prisma/schema.prisma",
)

bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@aws-sdk/client-s3",
        ":node_modules/@discordjs/voice",
        ":node_modules/@google/generative-ai",
        ":node_modules/@prisma/client",
        ":node_modules/@sentry/bun",
        ":node_modules/@trpc/server",
        ":node_modules/cron",
        ":node_modules/date-fns",
        ":node_modules/discord.js",
        ":node_modules/dotenv",
        ":node_modules/env-var",
        ":node_modules/openai",
        ":node_modules/prism-media",
        ":node_modules/prisma",
        ":node_modules/prom-client",
        ":node_modules/react",
        ":node_modules/remeda",
        ":node_modules/sodium-native",
        ":node_modules/ts-pattern",
        ":node_modules/tslog",
        ":node_modules/twisted",
        ":node_modules/uuid",
        ":node_modules/yoga-wasm-web",
        ":node_modules/zod",
        ":node_modules/zod-validation-error",
        "//packages/scout-for-lol/packages/data:pkg",
        "//packages/scout-for-lol/packages/report:pkg",
    ],
)

bun_binary(
    name = "backend",
    entry_point = "src/index.ts",
    deps = [":pkg"],
)

eslint_test(
    name = "lint",
    srcs = glob(["src/**/*.ts"]),
    config = "//packages/scout-for-lol:eslint.config.ts",
)

# Blocked: workspace packages (@scout-for-lol/data, @scout-for-lol/report) + #generated/prisma/client
# not resolved by tsc in sandbox.
bun_typecheck_test(
    name = "typecheck",
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    extra_files = ["//:tsconfig.base.json"],
    deps = [
        ":pkg",
        ":node_modules/typescript",
        "//:node_modules/@types/bun",
        "//:node_modules/undici-types",
    ],
)

# Blocked: tests use #generated/prisma/client (custom output path) which
# requires prisma generate with output to ./generated/prisma/client/ plus
# workspace packages (@scout-for-lol/data, @scout-for-lol/report).
bun_test(
    name = "test",
    size = "large",
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    deps = [":pkg"],
)
