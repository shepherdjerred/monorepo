{
  "name": "@shepherdjerred/eslint-config",
  "version": "0.3.0",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./rules": {
      "bun": "./src/rules/index.ts",
      "types": "./dist/rules/index.d.ts",
      "import": "./dist/rules/index.js",
      "default": "./src/rules/index.ts"
    },
    "./configs/*": {
      "bun": "./src/configs/*.ts",
      "types": "./dist/configs/*.d.ts",
      "import": "./dist/configs/*.js",
      "default": "./src/configs/*.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --outDir ./dist",
    "lint": "true",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "jiti": "^2.7.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-import-resolver-typescript-bun": "^0.0.104",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependencies": {
    "eslint": "^10.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.59.0",
    "@types/node": "^25.6.0"
  }
}
