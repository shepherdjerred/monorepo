{
  "name": "homelab",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shepherdjerred/eslint-config": "workspace:*",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "scripts": {
    "check:talos": "bun src/talos/update-image-id.ts --check",
    "lint:helm": "bash scripts/lint-helm.sh",
    "docker:build:caddy-s3proxy": "docker buildx build ${DOCKER_BUILD_EXTRA_ARGS:-} --load -t caddy-s3proxy:dev images/caddy-s3proxy",
    "docker:build:obsidian-headless": "docker buildx build ${DOCKER_BUILD_EXTRA_ARGS:-} --load -t obsidian-headless:dev images/obsidian-headless",
    "docker:build:mcp-gateway": "docker buildx build ${DOCKER_BUILD_EXTRA_ARGS:-} --load -t mcp-gateway:dev images/mcp-gateway",
    "docker:build:redlib": "docker buildx build ${DOCKER_BUILD_EXTRA_ARGS:-} --load -t redlib:dev images/redlib",
    "docker:build": "bun run docker:build:caddy-s3proxy && bun run docker:build:obsidian-headless && bun run docker:build:mcp-gateway && bun run docker:build:redlib",
    "smoke": "bun scripts/smoke-images.ts",
    "helm:push": "bun scripts/helm-push.ts",
    "tofu:stack": "bun scripts/tofu-stack.ts",
    "argocd": "bun scripts/argocd.ts"
  }
}
