{
  "mcpProxy": {
    "addr": ":9090",
    "name": "MCP Gateway",
    "version": "1.0.0",
    "options": {
      "authTokens": ["MCP_PROXY_AUTH_TOKEN_PLACEHOLDER"],
      "panicIfInvalid": true
    }
  },
  "mcpServers": {
    "canvas": {
      "command": "npx",
      "args": ["-y", "@r-huijts/canvas-mcp@CANVAS_MCP_VERSION"]
    },
    "home-assistant": {
      "transportType": "streamable-http",
      "url": "https://homeassistant.tailnet-1a49.ts.net/api/mcp",
      "headers": {
        "Authorization": "Bearer HOMEASSISTANT_TOKEN_PLACEHOLDER"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github@GITHUB_MCP_VERSION"]
    },
    "fastmail": {
      "transportType": "streamable-http",
      "url": "https://api.fastmail.com/mcp",
      "headers": {
        "Authorization": "Bearer FASTMAIL_TOKEN_PLACEHOLDER"
      }
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@automatearmy/email-reader-mcp@GMAIL_MCP_VERSION"],
      "options": {
        "panicIfInvalid": false
      }
    },
    "edstem": {
      "command": "node",
      "args": ["/opt/edstem-mcp/dist/index.js"]
    },
    "gradescope": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Yuanpeng-Li/gradescope-mcp.git@1e9743be7de62b14f9a6ddc843e2789ba6eb6d6e",
        "gradescope-mcp"
      ]
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "mcp-discord@1.3.4"]
    }
  }
}
