{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "lsp": true,
  "plugin": [
{{- if stat (joinPath .chezmoi.homeDir "git/opencode-kimi-full-kimi-api") }}
    {{ joinPath .chezmoi.homeDir "git/opencode-kimi-full-kimi-api" | toJson }},
{{- end }}
    "@slkiser/opencode-quota@3.11.2",
  ],
  "permission": {
    "bash": {
      "*": "allow",
      "sudo *": "deny",
      "su *": "deny",
      "rm -rf*": "deny",
      "rm -fr*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "newfs*": "deny",
      "shutdown*": "deny",
      "reboot*": "deny",
      "halt*": "deny",
      "poweroff*": "deny",
      "kubectl delete namespace *": "deny",
      "kubectl delete ns *": "deny",
      "kubectl delete node*": "deny",
      "kubectl delete pv *": "deny",
      "kubectl delete pv/*": "deny",
      "kubectl delete pvc *": "deny",
      "kubectl delete pvc/*": "deny",
      "kubectl delete persistentvolume*": "deny",
      "kubectl delete persistentvolumeclaim*": "deny",
      "kubectl drain *": "deny",
      "talosctl reset*": "deny",
      "talosctl wipe*": "deny",
      "argocd cluster rm*": "deny",
      "argocd app sync*--prune*": "deny",
      "helm uninstall*": "deny",
      "aws s3 rb*": "deny",
      "aws ec2 terminate*": "deny",
      "aws iam delete*": "deny",
      "gh repo delete*": "deny",
      "op vault delete*": "deny",
      "docker system prune*": "deny",
      "docker volume prune*": "deny",
      "docker volume rm*": "deny",
      "velero backup delete*": "deny",
      "sh": "deny",
      "bash": "deny",
      "zsh": "deny",
      "sh -": "deny",
      "bash -": "deny",
      "diskutil eraseDisk*": "deny",
      "diskutil eraseVolume*": "deny",
      "diskutil secureErase*": "deny",
      "diskutil zeroDisk*": "deny",
      "csrutil disable*": "deny",
      "csrutil clear*": "deny",
      "spctl --master-disable*": "deny",
      "nvram -c*": "deny",
      "nvram -d*": "deny",
      "parted *": "deny",
      "fdisk *": "deny",
      "sfdisk *": "deny",
      "gdisk *": "deny",
      "wipefs *": "deny",
      "crontab -r*": "deny",
      "kubectl delete crd*": "deny",
      "kubectl delete customresourcedefinition*": "deny",
      "kubectl delete --all *": "deny",
      "kubectl delete * --all-namespaces*": "deny",
    },
  },
  "provider": {
    "kimi-for-coding-oauth": {
      "name": "Kimi For Coding (OAuth)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1",
      },
      "models": {
        "kimi-for-coding": {
          "name": "K2.7 Coding",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "modalities": {
            "input": ["text", "image", "video"],
            "output": ["text"],
          },
          "options": {},
        },
        "kimi-for-coding-highspeed": {
          "name": "K2.7 Coding Highspeed",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "modalities": {
            "input": ["text", "image", "video"],
            "output": ["text"],
          },
          "options": {},
        },
        "k3": {
          "name": "K3",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "modalities": {
            "input": ["text", "image", "video"],
            "output": ["text"],
          },
          "options": {},
          "variants": {
            "low": { "reasoning_effort": "low" },
            "high": { "reasoning_effort": "high" },
            "max": { "reasoning_effort": "max" },
          },
        },
      },
    },
  },
}
