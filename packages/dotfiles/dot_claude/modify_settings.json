{{- /* chezmoi:modify-template */ -}}
{{- $data := dict -}}
{{- if ne .chezmoi.stdin "" -}}
{{-   $data = fromJson .chezmoi.stdin -}}
{{- end -}}
{{ $data |
  setValueAtPath "model" "opus" |
  setValueAtPath "permissions.deny" (list
    "Bash(sudo *)"
    "Bash(su *)"
    "Bash(rm -rf /*)"
    "Bash(rm -rf ~*)"
    "Bash(rm -fr /*)"
    "Bash(rm -fr ~*)"
    "Bash(dd *)"
    "Bash(mkfs*)"
    "Bash(shutdown*)"
    "Bash(reboot*)"
    "Bash(halt*)"
    "Bash(kubectl delete namespace *)"
    "Bash(kubectl delete ns *)"
    "Bash(kubectl delete node*)"
    "Bash(kubectl delete pv *)"
    "Bash(kubectl delete pv/*)"
    "Bash(kubectl delete pvc *)"
    "Bash(kubectl delete pvc/*)"
    "Bash(kubectl delete persistentvolume*)"
    "Bash(kubectl delete persistentvolumeclaim*)"
    "Bash(kubectl drain *)"
    "Bash(talosctl reset*)"
    "Bash(talosctl wipe*)"
    "Bash(argocd cluster rm*)"
    "Bash(argocd app sync*--prune*)"
    "Bash(helm uninstall*)"
    "Bash(aws s3 rb*)"
    "Bash(aws ec2 terminate*)"
    "Bash(aws iam delete*)"
    "Bash(gh repo delete*)"
    "Bash(op vault delete*)"
    "Bash(docker system prune*)"
    "Bash(docker volume prune*)"
    "Bash(docker volume rm*)"
    "Bash(velero backup delete*)"
    "Bash(coder delete*)"
  ) |
  setValueAtPath "permissions.ask" (list
    "Bash(git push --force*)"
    "Bash(git push -f *)"
    "Bash(git reset --hard*)"
    "Bash(git clean -f*)"
    "Bash(git branch -D*)"
    "Bash(git stash drop*)"
    "Bash(git stash clear*)"
    "Bash(npm publish*)"
    "Bash(bun publish*)"
    "Bash(docker push*)"
    "Bash(brew install*)"
    "Bash(brew uninstall*)"
    "Bash(npm install -g*)"
    "Bash(bun install -g*)"
    "Bash(kubectl delete *)"
    "Bash(kubectl apply *)"
    "Bash(kubectl scale *)"
    "Bash(kubectl edit *)"
    "Bash(kubectl rollout *)"
    "Bash(kubectl cordon *)"
    "Bash(kubectl uncordon *)"
    "Bash(kubectl patch *)"
    "Bash(kubectl label *)"
    "Bash(kubectl annotate *)"
    "Bash(kubectl taint *)"
    "Bash(talosctl apply-config*)"
    "Bash(talosctl upgrade*)"
    "Bash(helm install*)"
    "Bash(helm upgrade*)"
    "Bash(helm rollback*)"
    "Bash(argocd app delete*)"
    "Bash(argocd app sync*)"
    "Bash(argocd app set*)"
    "Bash(argocd app create*)"
    "Bash(gh pr merge*)"
    "Bash(gh pr close*)"
    "Bash(gh issue close*)"
    "Bash(gh release create*)"
    "Bash(gh release delete*)"
    "Bash(op item delete*)"
    "Bash(op item edit*)"
    "Bash(op item create*)"
    "Bash(docker rm *)"
    "Bash(docker stop *)"
    "Bash(docker kill *)"
    "Bash(docker compose down*)"
    "Bash(velero restore*)"
    "Bash(velero schedule*)"
    "Bash(aws s3 rm*)"
    "Bash(aws s3 cp*)"
    "Bash(aws s3 mv*)"
    "Bash(aws s3 sync*)"
    "Bash(coder create*)"
    "Bash(coder stop*)"
    "Bash(tailscale down*)"
  ) |
  setValueAtPath "permissions.allow" (list
    "Bash(*)"
    "Read(*)"
    "Edit(*)"
    "Write(*)"
    "WebSearch"
    "ListMcpResourcesTool"
    "ReadMcpResourceTool"
    "mcp__*"
  ) |
  setValueAtPath "enabledPlugins" (dict
    "feature-dev@claude-plugins-official" true
    "code-review@claude-plugins-official" true
    "commit-commands@claude-plugins-official" true
    "security-guidance@claude-plugins-official" true
    "pr-review-toolkit@claude-plugins-official" true
    "plugin-dev@claude-plugins-official" true
    "pyright-lsp@claude-plugins-official" true
    "typescript-lsp@claude-plugins-official" true
    "rust-analyzer-lsp@claude-plugins-official" true
    "gopls-lsp@claude-plugins-official" true
    "jdtls-lsp@claude-plugins-official" true
    "swift-lsp@claude-plugins-official" true
  ) |
  setValueAtPath "alwaysThinkingEnabled" true |
  setValueAtPath "terminalEditorMode" "vim" |
  toPrettyJson -}}
