load("@aspect_rules_js//js:defs.bzl", "js_binary", "js_library")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:bun_test.bzl", "bun_test")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/bazel:typecheck.bzl", "typecheck_test")
load("//tools/oci:bun_service_image.bzl", "bun_service_image")

npm_link_all_packages(name = "node_modules")

exports_files([
    "package.json",
    "tsconfig.json",
])

# Bun-native: TypeScript executed directly by Bun, no transpilation needed.
js_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]) + [
        "package.json",
    ],
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@ai-sdk/openai",
        ":node_modules/@opentelemetry/api",
        ":node_modules/@opentelemetry/exporter-trace-otlp-http",
        ":node_modules/@opentelemetry/resources",
        ":node_modules/@opentelemetry/sdk-node",
        ":node_modules/@opentelemetry/semantic-conventions",
        ":node_modules/@prisma/client",
        ":node_modules/@sentry/node",
        ":node_modules/@types/bun",
        ":node_modules/@voltagent/core",
        ":node_modules/@voltagent/libsql",
        ":node_modules/ai",
        ":node_modules/chrono-node",
        ":node_modules/cron-parser",
        ":node_modules/discord.js",
        ":node_modules/discord-player",
        ":node_modules/discord-player-youtubei",
        ":node_modules/hono",
        ":node_modules/mediaplex",
        ":node_modules/playwright",
        ":node_modules/youtubei.js",
        ":node_modules/zod",
    ],
)

js_binary(
    name = "birmel",
    data = [":pkg"],
    entry_point = "src/index.ts",
)

eslint_test(
    name = "lint",
    srcs = glob(["src/**/*.ts"]),
    tags = ["exclusive"],
)

typecheck_test(
    name = "typecheck",
    srcs = glob(["src/**/*.ts"]),
    tags = ["exclusive"],
)

bun_test(
    name = "test",
    srcs = glob(["src/**/*.ts"]),
    tags = ["exclusive"],
)

# Container image for K8s deployment
bun_service_image(
    name = "image",
    srcs = glob(["src/**/*.ts"]) + [
        "package.json",
        "prisma/schema.prisma",
    ],
    entry_point = "src/index.ts",
    env = {"NODE_ENV": "production"},
    labels = {
        "org.opencontainers.image.title": "birmel",
        "org.opencontainers.image.description": "AI-powered Discord server management bot",
        "org.opencontainers.image.source": "https://github.com/shepherdjerred/monorepo",
    },
    package_json = "package.json",
    repository = "ghcr.io/shepherdjerred/birmel",
    visibility = ["//visibility:public"],
)
