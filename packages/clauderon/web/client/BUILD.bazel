load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:bun_test.bzl", "bun_test")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/bazel:typecheck.bzl", "typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# Produce .d.ts declarations so downstream ts_project deps can type-check.
ts_project(
    name = "types",
    srcs = glob(
        ["src/**/*.ts"],
        exclude = ["src/**/*.test.ts"],
    ),
    declaration = True,
    emit_declaration_only = True,
    extends = "//:tsconfig_base",
    out_dir = "dist",
    root_dir = "src",
    tsconfig = "tsconfig.json",
    validate = False,
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@clauderon/shared",
        ":node_modules/@types/bun",
    ],
)

js_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]) + ["package.json"],
    visibility = ["//visibility:public"],
    deps = [
        ":types",
        "//packages/clauderon/web/shared:pkg",
    ],
)

eslint_test(
    name = "lint",
    srcs = glob(["src/**/*.ts"]),
    deps = ["//packages/clauderon/web/shared:pkg"],
)

typecheck_test(
    name = "typecheck",
    srcs = glob(["src/**/*.ts"]),
    deps = [
        ":node_modules/@clauderon/shared",
        ":node_modules/@types/bun",
    ],
)

bun_test(
    name = "test",
    srcs = glob(["src/**/*.ts"]),
    deps = [
        ":node_modules/@types/bun",
        "//packages/clauderon/web/shared:pkg",
    ],
)
