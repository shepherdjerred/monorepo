load("@bun_modules//:defs.bzl", "bun_link_all_packages")
load("@bun_modules2//:defs.bzl", bun2_link = "npm_link_all_packages")
load("//tools/rules_bun/bun:defs.bzl", "bun_binary", "bun_eslint_test", "bun_library", "bun_prepared_tree", "bun_prisma_generate", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")
load("//tools/rules_bun2/bun:defs.bzl", bun2_eslint_test = "bun_eslint_test", bun2_library = "bun_library", bun2_test = "bun_test", bun2_typecheck_test = "bun_typecheck_test")

bun_link_all_packages(name = "node_modules")
bun2_link(name = "node_modules2")

exports_files(["package.json"])

filegroup(
    name = "testdata",
    srcs = glob(["src/league/model/__tests__/testdata/**"]),
    visibility = ["//packages/scout-for-lol/packages/data:__pkg__"],
)

# Prisma client generation with branded types post-processing.
bun_prisma_generate(
    name = "prisma_generate",
    post_generate_deps = [
        "src/logger.ts",
    ],
    post_generate_script = "scripts/brand-prisma-types.ts",
    schema = "prisma/schema.prisma",
)

bun_library(
    name = "pkg",
    package_name = "@scout-for-lol/backend",
    srcs = glob(
        ["src/**/*.ts"],
        exclude = [
            "**/*.test.ts",
            "**/*.spec.ts",
        ],
    ),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@aws-sdk/client-s3",
        ":node_modules/@discordjs/voice",
        ":node_modules/@google/generative-ai",
        ":node_modules/@prisma/client",
        ":node_modules/@sentry/bun",
        ":node_modules/@trpc/server",
        ":node_modules/cron",
        ":node_modules/date-fns",
        ":node_modules/discord.js",
        ":node_modules/dotenv",
        ":node_modules/env-var",
        ":node_modules/openai",
        ":node_modules/prism-media",
        ":node_modules/prisma",
        ":node_modules/prom-client",
        ":node_modules/react",
        ":node_modules/remeda",
        ":node_modules/sodium-native",
        ":node_modules/ts-pattern",
        ":node_modules/tslog",
        ":node_modules/twisted",
        ":node_modules/uuid",
        ":node_modules/yoga-wasm-web",
        ":node_modules/zod",
        ":node_modules/zod-validation-error",
        "//packages/scout-for-lol/packages/data:pkg",
        "//packages/scout-for-lol/packages/report:pkg",
    ],
)

bun_prepared_tree(
    name = "tree",
    extra_files = [
        "tsconfig.json",
        "//:tsconfig.base.json",
        "//packages/scout-for-lol:eslint.config.ts",
        "//packages/scout-for-lol:tsconfig.base.json",
    ],
    prisma_client = ":prisma_generate",
    tsconfig = "tsconfig.json",
    deps = [
        ":node_modules/typescript",
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/undici-types",
        "//packages/eslint-config:pkg",
    ],
)

bun_binary(
    name = "backend",
    entry_point = "src/index.ts",
    prepared_tree = ":tree",
)

bun_eslint_test(
    name = "lint",
    prepared_tree = ":tree",
    tags = ["manual"],
)

# Blocked: workspace packages (@scout-for-lol/data, @scout-for-lol/report) + #generated/prisma/client
# not resolved by tsc in sandbox.
bun_typecheck_test(
    name = "typecheck",
    prepared_tree = ":tree",
    tags = ["manual"],
)

# Blocked: tests use #generated/prisma/client (custom output path) which
# requires prisma generate with output to ./generated/prisma/client/ plus
# workspace packages (@scout-for-lol/data, @scout-for-lol/report).
bun_test(
    name = "test",
    prepared_tree = ":tree",
    size = "large",
    tags = ["manual"],
)

# ── rules_bun2 targets ──────────────────────────────────────────────

bun2_library(
    name = "pkg2",
    srcs = glob(
        ["src/**/*.ts"],
        exclude = [
            "**/*.test.ts",
            "**/*.spec.ts",
        ],
    ) + ["package.json"],
    package_name = "@scout-for-lol/backend",
    visibility = ["//visibility:public"],
    deps = [
        "//packages/scout-for-lol/packages/data:pkg2",
        "//packages/scout-for-lol/packages/report:pkg2",
    ],
)

bun2_typecheck_test(
    name = "typecheck2",
    srcs = glob(["src/**/*.ts"]),
    extra_files = [
        "tsconfig.json",
        "//packages/scout-for-lol:tsconfig.base.json",
        "//:tsconfig.base.json",
    ],
    generated_dirs = {":prisma_generate": "generated/prisma/client"},
    node_modules = ":node_modules2",
    deps = [
        ":pkg2",
        "//packages/scout-for-lol/packages/data:pkg2",
        "//packages/scout-for-lol/packages/report:pkg2",
    ],
)

bun2_eslint_test(
    name = "lint2",
    srcs = glob(
        ["src/**/*.ts"],
        exclude = ["src/**/*.test.ts"],
    ),
    extra_files = [
        "//packages/scout-for-lol:eslint.config.ts",
        "tsconfig.json",
        "//packages/scout-for-lol:tsconfig.base.json",
        "//:tsconfig.base.json",
    ],
    generated_dirs = {":prisma_generate": "generated/prisma/client"},
    node_modules = ":node_modules2",
    deps = [
        ":pkg2",
        "//packages/eslint-config:pkg2",
        "//packages/scout-for-lol/packages/data:pkg2",
        "//packages/scout-for-lol/packages/report:pkg2",
    ],
)

bun2_test(
    name = "test2",
    size = "large",
    srcs = glob(
        [
            "src/**/*.test.ts",
            "src/**/*.spec.ts",
        ],
        allow_empty = True,
    ),
    extra_files = [
        "tsconfig.json",
        "//packages/scout-for-lol:tsconfig.base.json",
        "//:tsconfig.base.json",
    ],
    generated_dirs = {":prisma_generate": "generated/prisma/client"},
    node_modules = ":node_modules2",
    deps = [
        ":pkg2",
        "//packages/scout-for-lol/packages/data:pkg2",
        "//packages/scout-for-lol/packages/report:pkg2",
    ],
)
