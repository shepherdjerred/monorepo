{
  "name": "@shepherdjerred/discord-stream-lifecycle",
  "version": "0.0.2",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun run build && bun test test/",
    "typecheck": "bun run build && tsc --noEmit",
    "lint": "bun run build && eslint ."
  },
  "dependencies": {
    "xstate": "^5.32.4"
  },
  "peerDependencies": {
    "discord.js": "^14.26.4",
    "discord.js-selfbot-v13": "^3.6.1"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "workspace:*",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.0.0",
    "@typescript-eslint/utils": "^8.59.3",
    "discord.js": "^14.26.4",
    "discord.js-selfbot-v13": "^3.7.1",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3"
  }
}
