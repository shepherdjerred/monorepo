{
  "name": "tasknotes-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile=dist/tasknotes-server",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "bunx eslint . --max-warnings=0"
  },
  "dependencies": {
    "@sentry/bun": "^10.49.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.14",
    "prom-client": "^15.1.3",
    "tasknotes-types": "file:../tasknotes-types",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@types/bun": "latest",
    "eslint": "^10.0.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
