load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/rules_bun/bun:defs.bzl", "bun_binary", "bun_eslint_test", "bun_library", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@anthropic-ai/sdk",
        ":node_modules/monarch-money-api",
        ":node_modules/pdfjs-dist",
        ":node_modules/playwright",
        ":node_modules/zod",
    ],
)

bun_binary(
    name = "monarch",
    entry_point = "src/index.ts",
    deps = [":pkg"],
)

bun_eslint_test(
    name = "lint",
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//:tsconfig.base.json",
    ],
    deps = [
        ":node_modules/typescript",
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/undici-types",
        "//packages/eslint-config:pkg",
    ],
)

bun_typecheck_test(
    name = "typecheck",
    extra_files = ["//:tsconfig.base.json"],
    tsconfig = "tsconfig.json",
    deps = [
        ":node_modules/typescript",
        ":pkg",
        "//:node_modules/bun-types",
        "//:node_modules/undici-types",
    ],
)

bun_test(
    name = "test",
    tags = ["no-sandbox"],
    tsconfig = "tsconfig.json",
    deps = [":pkg"],
)
