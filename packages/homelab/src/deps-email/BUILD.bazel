load("@aspect_bazel_lib//lib:expand_template.bzl", "expand_template")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("@rules_oci//oci:defs.bzl", "oci_image", "oci_push")
load("//tools/oci:bun_service_image.bzl", "bun_service_image")
load("//tools/rules_bun/bun:defs.bzl", "bun_eslint_test", "bun_library")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# Dependency email notifications — runs Bun scripts.
bun_library(
    name = "pkg",
    srcs = glob(["src/**/*.ts"]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/openai",
        ":node_modules/simple-git",
        ":node_modules/yaml",
        ":node_modules/zod",
    ],
)

bun_eslint_test(
    name = "lint",
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//packages/homelab:tsconfig.base.json",
    ],
    deps = [
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/typescript",
        "//:node_modules/undici-types",
        "//packages/eslint-config:pkg",
    ],
)

bun_typecheck_test(
    name = "typecheck",
    extra_files = ["//packages/homelab:tsconfig.base.json"],
    tags = ["manual"],
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/typescript",
        "//:node_modules/undici-types",
    ],
)

# Container image for K8s deployment.
# Two-stage: bun_service_image creates the base, then we add git + helm on top
# (simple-git needs git CLI, image-extractor needs helm CLI at runtime).
bun_service_image(
    name = "image_base",
    srcs = glob(["src/**/*.ts"]) + ["package.json"],
    entry_point = "src/main.ts",
    env = {"NODE_ENV": "production"},
    labels = {
        "org.opencontainers.image.title": "dependency-summary",
        "org.opencontainers.image.description": "Dependency update email notifications",
        "org.opencontainers.image.source": "https://github.com/shepherdjerred/monorepo",
    },
    package_json = "package.json",
    visibility = ["//visibility:public"],
    workspace_packages = {
        "packages/homelab/src/cdk8s": "//packages/homelab/src/cdk8s:pkg",
        "packages/homelab/src/helm-types": "//packages/homelab/src/helm-types:pkg",
        "packages/homelab/src/ha": "//packages/homelab/src/ha:pkg",
    },
)

oci_image(
    name = "image",
    base = ":image_base",
    tags = ["manual"],
    tars = [
        "//tools/oci:git_layer",
        "//tools/oci:helm_layer",
    ],
    visibility = ["//visibility:public"],
)

genrule(
    name = "image_tags_tmpl",
    outs = ["image_tags_tmpl.txt"],
    cmd = "echo '{STABLE_GIT_SHA}' > $@",
    tags = ["manual"],
)

expand_template(
    name = "image_tags",
    out = "image_tags.txt",
    stamp_substitutions = {"{STABLE_GIT_SHA}": "{{STABLE_GIT_SHA}}"},
    tags = ["manual"],
    template = ":image_tags_tmpl",
)

oci_push(
    name = "image_push",
    image = ":image",
    remote_tags = ":image_tags",
    repository = "ghcr.io/shepherdjerred/dependency-summary",
    tags = ["manual"],
    visibility = ["//visibility:public"],
)
