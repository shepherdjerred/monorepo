# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'TasksForObsidian' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_configuration|
        # Xcode 26 treats some pod header/module combinations as errors.
        build_configuration.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        # Xcode 27 refuses deployment targets below iOS 15; some pods
        # (e.g. AsyncStorage's resource-bundle target) still pin 13.0.
        deployment_target = build_configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
        if deployment_target != nil && deployment_target.to_f < 15.0
          build_configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
        end

        # react-native-ios-context-menu uses iOS-16-only API (UIAction
        # `subtitle`) without availability guards but its podspec declares
        # an older platform — it only compiles with a 16.0 target.
        if target.name == 'react-native-ios-context-menu'
          build_configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        end

        # fmt 11.0.2 fails with consteval checks under Apple Clang in Xcode 26
        # when built as C++20. Keep fmt on C++17 only.
        if target.name == 'fmt'
          build_configuration.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
        end
      end
    end
  end
end
