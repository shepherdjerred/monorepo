{
  "name": "@shepherdjerred/toolkit",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    "./lib/*": "./src/lib/*"
  },
  "imports": {
    "#lib/*": "./src/lib/*",
    "#commands/*": "./src/commands/*",
    "#daemon/*": "./src/daemon/*"
  },
  "bin": {
    "toolkit": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --compile --outfile=dist/toolkit",
    "test": "true",
    "test:unit": "bun test test/recall test/fetch test/daemon --exclude '*integration*'",
    "test:integration": "bun test test/**/*integration*",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@types/bun": "latest",
    "eslint": "^9.39.2",
    "typescript": "latest"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.1",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  }
}
