# Required - Discord Bot Credentials
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Required - AI Services
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_CLASSIFIER_MODEL=gpt-5.4-nano
OPENAI_REASONING_EFFORT=medium
OPENAI_TEXT_VERBOSITY=low

# Optional - Database
DATABASE_PATH=./data/birmel.db

# Optional - Daily Posts
DAILY_POSTS_ENABLED=true
DAILY_POST_TIME=09:00
DAILY_POST_TIMEZONE=America/Los_Angeles

# Optional - Voice/TTS
TTS_VOICE=nova
TTS_SPEED=1.0
VOICE_ENABLED=true

# Optional - live music E2E (`bun run test:e2e:music`) and YouTube stream E2E (`bun run test:e2e:youtube-stream`)
BIRMEL_E2E_GUILD_ID=
BIRMEL_E2E_TEXT_CHANNEL_ID=
BIRMEL_E2E_VOICE_CHANNEL_ID=
BIRMEL_E2E_YOUTUBE_QUERY=
BIRMEL_E2E_PLAYBACK_SECONDS=5
BIRMEL_E2E_TIMEOUT_MS=45000

# Optional - External APIs
NEWS_API_KEY=
RIOT_API_KEY=
WEB_SEARCH_PROVIDER=openai

# Optional - Browser automation
BROWSER_PROVIDER=pinchtab
PINCHTAB_BASE_URL=http://localhost:9867
PINCHTAB_TOKEN=
PINCHTAB_PROFILE=birmel

# Optional - Observability
LOG_LEVEL=info
# SENTRY_DSN=https://4fec575b459a4afe9b1230d29313a64c@bugsink.sjer.red/7
# OTLP_ENDPOINT=http://tempo.tempo.svc.cluster.local:4318
# TELEMETRY_ENABLED=true

# Optional - Memory store
# MEMORY_DB_PATH=file:/app/data/birmel-memory.db

# Optional - Conversational responder (GPT-nano follow-up trigger + transcript)
# RESPONDER_ENABLED=true
# RESPONDER_ENGAGEMENT_WINDOW_MS=180000
# RESPONDER_TRANSCRIPT_MIN_MESSAGES=25
# RESPONDER_TRANSCRIPT_WINDOW_MS=3600000
# RESPONDER_TRANSCRIPT_MAX_MESSAGES=100
# OPENAI_CLASSIFIER_MODEL=gpt-5.4-nano
