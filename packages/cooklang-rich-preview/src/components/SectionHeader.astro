---
import Badge from "./Badge.astro";

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
}

const { title, subtitle, badge } = Astro.props;
---

<div class="mx-auto max-w-2xl text-center">
  {badge && <Badge text={badge} />}
  <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
    {title}
  </h2>
  {subtitle && <p class="mt-4 text-base text-gray-600 dark:text-gray-400">{subtitle}</p>}
</div>
