load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:bun_test.bzl", "bun_test")
load("//tools/bazel:eslint.bzl", "eslint_test")
load("//tools/bazel:typecheck.bzl", "typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# .gitkeep ensures the dist/ directory exists in the source tree for
# include_dir! in Rust compilation. Force-added to git despite .gitignore.
exports_files(
    ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "dist_gitkeep",
    srcs = ["dist/.gitkeep"],
    visibility = ["//visibility:public"],
)

# Vite/React SPA; this js_library wraps sources for dependency tracking.
js_library(
    name = "pkg",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
    ]) + ["package.json"],
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/react",
        ":node_modules/react-dom",
        ":node_modules/zod",
        "//packages/clauderon/web/client:pkg",
        "//packages/clauderon/web/shared:pkg",
    ],
)

eslint_test(
    name = "lint",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
    ]),
    deps = [
        "//packages/clauderon/web/client:pkg",
        "//packages/clauderon/web/shared:pkg",
    ],
)

typecheck_test(
    name = "typecheck",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
    ]),
    deps = [
        ":node_modules/@clauderon/client",
        ":node_modules/@clauderon/shared",
        ":node_modules/@github/webauthn-json",
        ":node_modules/@radix-ui/react-dialog",
        ":node_modules/@radix-ui/react-dropdown-menu",
        ":node_modules/@radix-ui/react-label",
        ":node_modules/@radix-ui/react-select",
        ":node_modules/@radix-ui/react-slot",
        ":node_modules/@radix-ui/react-tabs",
        ":node_modules/@radix-ui/react-tooltip",
        ":node_modules/@sentry/react",
        ":node_modules/@types/bun",
        ":node_modules/@types/react",
        ":node_modules/@types/react-dom",
        ":node_modules/class-variance-authority",
        ":node_modules/clsx",
        ":node_modules/ghostty-web",
        ":node_modules/lucide-react",
        ":node_modules/react",
        ":node_modules/react-dom",
        ":node_modules/react-markdown",
        ":node_modules/remark-gfm",
        ":node_modules/shiki",
        ":node_modules/sonner",
        ":node_modules/tailwind-merge",
        ":node_modules/vite",
        ":node_modules/zod",
    ],
)

bun_test(
    name = "test",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
    ]),
    deps = [
        ":node_modules/@types/bun",
        ":node_modules/react",
        ":node_modules/react-dom",
        ":node_modules/zod",
        "//packages/clauderon/web/client:pkg",
        "//packages/clauderon/web/shared:pkg",
    ],
)
