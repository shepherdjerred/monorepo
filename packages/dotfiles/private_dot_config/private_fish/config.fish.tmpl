# Add common paths (OS-specific to avoid testing nonexistent dirs)
{{ if eq .chezmoi.os "darwin" -}}
fish_add_path /opt/homebrew/bin ~/bin ~/.local/bin
{{ else -}}
fish_add_path /home/linuxbrew/.linuxbrew/bin ~/bin ~/.local/bin
{{ end -}}

# Ghostty shell integration
if set -q GHOSTTY_RESOURCES_DIR
    source "$GHOSTTY_RESOURCES_DIR"/shell-integration/fish/vendor_conf.d/ghostty-shell-integration.fish
end

# Disable vendor conf.d auto-activation (expensive full hook mode ~23ms)
# and use only --shims mode (~2ms, just adds PATH entry)
set -gx MISE_FISH_AUTO_ACTIVATE 0
mise activate fish --shims | source

# Use abbreviations so scripts use real commands, but your typing expands
abbr vim nvim
abbr ls eza
abbr grep rg
abbr cat bat
abbr htop "sudo btop"
abbr top "sudo btop"
abbr btop "sudo btop"
abbr less ov
abbr ping gping
abbr claude "claude --allow-dangerously-skip-permissions"
abbr finder "open -a Finder"

