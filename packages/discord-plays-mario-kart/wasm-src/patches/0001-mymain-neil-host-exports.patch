+uint8_t* volatile g_injectedRom = 0;
+volatile int g_injectedRomSize = 0;
+EMSCRIPTEN_KEEPALIVE void neilSetRom(int ptr, int size) { g_injectedRom = (uint8_t*)(intptr_t)ptr; g_injectedRomSize = size; }
