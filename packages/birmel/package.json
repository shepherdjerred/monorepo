{
  "name": "@shepherdjerred/birmel",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "bunx --trust prisma generate && bunx prisma db push && bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "true",
    "generate": "bunx --trust prisma generate",
    "test": "bunx --env-file=.env.test --trust prisma generate && bun --env-file=.env.test test",
    "typecheck": "bunx --trust prisma generate && tsc --noEmit",
    "lint": "bunx --trust prisma generate && eslint ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@libsql/client": "0.17.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/bun": "^10.49.0",
    "@voltagent/core": "^2.7.4",
    "@voltagent/libsql": "^2.1.2",
    "ai": "^6.0.180",
    "chrono-node": "^2.9.1",
    "cron-parser": "^5.5.0",
    "discord-player": "7.2.0",
    "discord-player-youtubei": "^2.0.0",
    "discord.js": "^14.26.4",
    "hono": "^4.12.18",
    "mediaplex": "^1.0.0",
    "playwright": "^1.60.0",
    "youtube-dl-exec": "^3.1.6",
    "youtubei.js": "^17.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shepherdjerred/eslint-config": "file:../eslint-config",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.1"
  }
}
