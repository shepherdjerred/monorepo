  },
  "type": "module",
  "version": "1.6.1",
  "scripts": {
    "lint": "eslint src --cache",
    "build": "tsc",
    "watch": "tsc -w",
    "test": "bun test src/",
    "test:update": "bun test src/ --update-snapshots",
