{
  "config": {
    "line-length": false,
    "no-inline-html": false,
    "code-block-style": false,
    "no-duplicate-heading": {
      "siblings_only": true,
    },
    "no-bare-urls": false,
    "no-alt-text": false,
    "no-empty-links": false,
    "first-line-heading": false,
    "single-title": false,
    "heading-increment": false,
    "no-emphasis-as-heading": false,
    "no-trailing-punctuation": false,
    "ol-prefix": false,
    "commands-show-output": false,
    "emphasis-style": false,
    "fenced-code-language": false,
    "link-fragments": false,
  },
  "ignores": [
    "sandbox/archive/**",
    // Gitignored Claude Code local state; worktrees under .claude/worktrees are
    // other branches' checkouts and lint in their own runs, not this one.
    ".claude/**",
    // Test fixtures are content under test, not documentation.
    "**/__tests__/fixtures/**",
    "**/e2e/fixtures/**",
    "**/node_modules/**",
    "**/.venv/**",
    "**/generated/**",
    "**/dist/**",
    "**/build/**",
    "**/.build/**",
    "**/target/**",
    "**/Pods/**",
    "**/test-results/**",
    "**/playwright-report/**",
    "**/_summary.md",
    "**/ai_dev_log/**",
    "**/CHANGELOG.md",
    "packages/discord-plays-pokemon/packages/frontend/public/emulatorjs/**",
    "**/wasm-src/**",
    "sandbox/practice/**",
    "**/.terraform/**",
    "packages/dotfiles/dot_agents/skills/**",
    "packages/discord-video-stream/**",
  ],
}
