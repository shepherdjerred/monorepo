load("@bun_modules//:defs.bzl", "bun_link_all_packages")
load("//tools/rules_bun/bun:defs.bzl", "bun_eslint_test", "bun_library", "bun_prepared_tree", "bun_test")
load("//tools/rules_bun/ts:defs.bzl", "bun_typecheck_test")

bun_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# CDK8s infrastructure-as-code — stub bun_library for dependency tracking.
# Full cdk8s synth build is complex and not yet integrated.
bun_library(
    name = "pkg",
    srcs = glob([
        "src/**/*.ts",
        "generated/**/*.ts",
        "grafana/**/*.ts",
    ]),
    package_json = "package.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@grafana/grafana-foundation-sdk",
        ":node_modules/@types/lodash",
        ":node_modules/cdk8s",
        ":node_modules/cdk8s-plus-31",
        ":node_modules/constructs",
        ":node_modules/cron-parser",
        ":node_modules/lodash",
        ":node_modules/remeda",
        ":node_modules/ts-pattern",
        ":node_modules/type-fest",
        ":node_modules/zod",
        "//packages/homelab/src/helm-types:pkg",
    ],
)

bun_prepared_tree(
    name = "tree",
    data = glob(
        [
            "config/**",
            "helm/**",
            "src/**/*.sh",
            "src/**/*.py",
            "src/**/*.yml",
            "src/**/*.yaml",
            "src/**/*.json",
        ],
        allow_empty = True,
        exclude = ["**/node_modules/**"],
    ) + [
        "//packages/homelab:scripts/lint-helm.sh",
    ],
    extra_files = [
        "eslint.config.ts",
        "tsconfig.json",
        "//packages/homelab:tsconfig.base.json",
    ],
    tsconfig = "tsconfig.json",
    deps = [
        ":pkg",
        "//:node_modules/@types/bun",
        "//:node_modules/typescript",
        "//:node_modules/undici-types",
        "//packages/eslint-config:pkg",
    ],
)

bun_eslint_test(
    name = "lint",
    prepared_tree = ":tree",
)

# Manual: cdk8s tsconfig path aliases not resolved in Bazel sandbox
bun_typecheck_test(
    name = "typecheck",
    prepared_tree = ":tree",
    tags = ["manual"],
)

# Manual: tsconfig path aliases need local execution; Bun resolves them from bin tree
bun_test(
    name = "test",
    size = "large",
    local = True,
    prepared_tree = ":tree",
    tags = ["manual"],
)
