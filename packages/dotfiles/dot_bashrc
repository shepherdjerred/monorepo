# ~/.bashrc - Sourced by interactive non-login shells

# Source environment setup (PATH, mise)
[[ -f ~/.bash_env ]] && source ~/.bash_env

# Aliases (interactive only)
alias vim=nvim
alias ls=eza
alias grep=rg
alias cat=bat
alias htop=btop
alias top=btop

# Environment
export SHELL=bash
export EDITOR=nvim
export LANG=en_US.UTF-8
