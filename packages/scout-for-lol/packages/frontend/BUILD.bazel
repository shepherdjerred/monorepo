load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools/bazel:typecheck.bzl", "typecheck_test")

npm_link_all_packages(name = "node_modules")

exports_files(["package.json"])

# Astro build is complex; this js_library wraps sources for dependency tracking.
js_library(
    name = "pkg",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.astro",
        "src/**/*.css",
    ]) + ["package.json"],
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules/@astrojs/mdx",
        ":node_modules/@astrojs/react",
        ":node_modules/@astrojs/tailwind",
        ":node_modules/@trpc/client",
        ":node_modules/astro",
        ":node_modules/react",
        ":node_modules/react-dom",
        ":node_modules/zod",
        "//packages/scout-for-lol/packages/data:pkg",
        "//packages/scout-for-lol/packages/report:pkg",
    ],
)

typecheck_test(
    name = "typecheck",
    srcs = glob([
        "src/**/*.ts",
        "src/**/*.tsx",
    ]),
    data = ["package.json"],
    extends = "//packages/scout-for-lol:tsconfig_base",
    deps = [
        ":node_modules/@astrojs/mdx",
        ":node_modules/@astrojs/react",
        ":node_modules/@astrojs/tailwind",
        ":node_modules/@aws-sdk/client-s3",
        ":node_modules/@google/generative-ai",
        ":node_modules/@radix-ui/react-dialog",
        ":node_modules/@radix-ui/react-navigation-menu",
        ":node_modules/@radix-ui/react-slot",
        ":node_modules/@scout-for-lol/data",
        ":node_modules/@scout-for-lol/report",
        ":node_modules/@trpc/client",
        ":node_modules/@types/react",
        ":node_modules/@types/react-dom",
        ":node_modules/astro",
        ":node_modules/bun-types",
        ":node_modules/class-variance-authority",
        ":node_modules/clsx",
        ":node_modules/date-fns",
        ":node_modules/fuse.js",
        ":node_modules/lucide-react",
        ":node_modules/openai",
        ":node_modules/react",
        ":node_modules/react-dom",
        ":node_modules/tailwind-merge",
        ":node_modules/zod",
        "//:node_modules/@types/bun",
        "//:node_modules/@types/node",
        "//:node_modules/undici-types",
        "//packages/scout-for-lol/packages/data:pkg",
        "//packages/scout-for-lol/packages/report:pkg",
    ],
)
