{
  "name": "clauderon-mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "macos": "react-native run-macos",
    "windows": "npx @react-native-community/cli run-windows",
    "start": "react-native start",
    "test": "bun test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "test:windows": "jest --config jest.config.windows.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@react-navigation/stack": "^7.8.10",
    "@sentry/react-native": "^7.13.0",
    "react": "19.2.4",
    "react-macos": "npm:react@19.1.4",
    "react-native": "0.83.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-image-picker": "^7.2.3",
    "react-native-markdown-display": "^7.0.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "4.24.0",
    "react-native-syntax-highlighter": "^2.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@react-native-community/cli": "^18.0.1",
    "@react-native-community/cli-platform-android": "^18.0.1",
    "@react-native-community/cli-platform-ios": "^18.0.1",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@rnx-kit/jest-preset": "^0.3.1",
    "@shepherdjerred/eslint-config": "file:../../eslint-config",
    "@types/react": "~19.2.14",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.3.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "react-native-macos": "^0.81.7",
    "react-native-windows": "^0.82.3",
    "react-test-renderer": "19.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "ClauderonMobile",
      "namespace": "ClauderonMobile",
      "template": "cpp-app"
    }
  }
}
