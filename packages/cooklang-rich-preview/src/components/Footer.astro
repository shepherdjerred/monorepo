---
import { Icon } from "astro-icon/components";
---

<footer class="border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto max-w-7xl px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-xs text-gray-500 dark:text-gray-500">
      &copy; {new Date().getFullYear()} Jerred Shepherd
    </p>
    <div class="flex items-center gap-6">
      <a
        href="https://cooklang.org"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-500 hover:text-gray-900 dark:hover:text-gray-300 transition-colors"
      >
        <Icon name="heroicons:book-open" class="h-3.5 w-3.5" />
        Cooklang
      </a>
      <a
        href="https://github.com/shepherdjerred/cooklang-for-obsidian"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-500 hover:text-gray-900 dark:hover:text-gray-300 transition-colors"
      >
        <Icon name="heroicons:code-bracket" class="h-3.5 w-3.5" />
        GitHub
      </a>
    </div>
  </div>
</footer>
