{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "packages/birmel": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/tools": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/eslint-config": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/astro-opengraph-images": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/better-skill-capped": {
      "entry": ["src/index.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/sjer.red": {
      "entry": ["src/**/*.astro", "astro.config.ts"],
      "project": ["src/**/*.{ts,tsx,astro}"]
    },
    "packages/webring": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/starlight-karma-bot": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/homelab/src/cdk8s": {
      "entry": ["src/app.ts", "src/**/*.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/homelab/src/helm-types": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/discord-plays-pokemon/packages/backend": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/discord-plays-pokemon/packages/common": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/discord-plays-pokemon/packages/frontend": {
      "entry": ["src/main.tsx", "vite.config.ts"],
      "project": ["src/**/*.{ts,tsx}", "*.ts"]
    },
    "packages/scout-for-lol/packages/backend": {
      "entry": ["src/index.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/scout-for-lol/packages/data": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/scout-for-lol/packages/report": {
      "entry": ["src/index.ts", "build.ts"],
      "project": ["src/**/*.{ts,tsx}", "*.ts"]
    },
    "packages/scout-for-lol/packages/frontend": {
      "entry": ["astro.config.ts", "src/**/*.tsx", "src/*-stub.ts"],
      "project": ["src/**/*.{ts,tsx,astro}", "*.ts"]
    },
    "packages/scout-for-lol/packages/desktop": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "vite": false,
      "postcss": false
    },
    "packages/scout-for-lol/packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/clauderon/web/client": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/clauderon/web/frontend": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/clauderon/web/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/clauderon/docs": {
      "entry": ["astro.config.mjs", "src/**/*.{ts,tsx,astro,mdx}"],
      "project": ["src/**/*.{ts,tsx,astro,mdx}", "*.mjs"]
    },
    "packages/cooklang-rich-preview": {
      "entry": ["astro.config.mjs", "src/**/*.astro"],
      "project": ["src/**/*.{ts,tsx,astro}", "*.ts"]
    },
    "packages/hn-enhancer": {
      "entry": [
        "src/background/index.ts",
        "src/content/index.ts",
        "src/popup/popup.ts",
        "vite.config.ts"
      ],
      "project": ["src/**/*.ts", "*.ts"]
    },
    "packages/monarch": {
      "entry": ["src/index.ts", "src/lib/*/classify.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/leetcode": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/toolkit": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/tasknotes-server": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/tasknotes-types": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/homelab": {
      "entry": ["scripts/**/*.ts", "eslint.config.ts"],
      "project": ["scripts/**/*.ts", "eslint.config.ts"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "ignore": [
    "**/eslint.config.ts",
    "**/postcss.config.ts",
    "**/generated/**",
    "**/dist/**",
    "archive/**",
    ".dagger/**",
    "practice/**",
    "packages/clauderon/mobile/**",
    "packages/castle-casters/**",
    "packages/macos-cross-compiler/**",
    "packages/resume/**",
    "packages/dotfiles/**",
    "packages/fonts/**",
    "packages/anki/**",
    "packages/webring/example/**",
    "packages/cooklang-for-obsidian/**",
    "packages/tasks-for-obsidian/**",
    "packages/bun-decompile/**",
    "packages/scout-for-lol/scripts/**",
    "packages/docs/**",
    "poc/**",
    "scripts/**"
  ]
}
