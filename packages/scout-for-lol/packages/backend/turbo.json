{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    // Dependents (e.g. @scout-for-lol/frontend, which typechecks backend
    // source via a relative import) only reach this package through the
    // root pipeline's "^build" edges — never through "generate" directly,
    // since root turbo.json's bare "generate" dependency on typecheck/test
    // resolves to the SAME package's own generate task, not a dependency's.
    // Without this edge, a dependent pulled into --affected scope without
    // this package also being affected (e.g. a PR touching only a package
    // frontend depends on) never schedules this package's Prisma codegen,
    // so #generated/prisma/client is missing and dependent typechecks fail.
    "build": {
      "dependsOn": ["generate"]
    },
    // test script interpolates ${DATABASE_URL:-file:./test.db} — ambient value
    // changes results. Everything else is pinned by the test-setup preload.
    "test": {
      "env": ["DATABASE_URL"]
    },
    // Typed lint (projectService) resolves the generated Prisma client; root's
    // lint task only depends on ^build, so on a cold container lint raced
    // generate and every prisma.competitionParticipant access became an error
    // type (build 5789). Same edge typecheck/test already carry via root.
    "lint": {
      "dependsOn": ["^build", "generate"]
    },
    // generate also produces the test template DB (undeclared outputs don't
    // restore from cache). ^build is a real dependency: the template-DB seed
    // imports @scout-for-lol/data → @shepherdjerred/llm-models, whose exports
    // only resolve from its built dist/ (fresh checkouts fail without it).
    // The birmel edge is NOT a real dependency: it serializes this prisma
    // generate against birmel's so two concurrent runs don't race Prisma's
    // shared engine/download cache (same synthetic edge the old setup.ts DAG
    // carried; observed flaky at -c 4 without it).
    "generate": {
      "dependsOn": ["^build", "@shepherdjerred/birmel#generate"],
      "outputs": ["generated/**", "src/testing/template.db"]
    },
    // template.db must match migrations + seed inputs (old CI:
    // scout-test-template-check). Seed data includes ../data/src/seasons.ts —
    // turbo inputs can't cross packages, so the @scout-for-lol/data#typecheck
    // edge stands in: any data-package source change re-runs this check
    // (over-invalidation, never under-invalidation).
    "check:test-template": {
      "dependsOn": ["generate", "@scout-for-lol/data#typecheck"],
      "inputs": [
        "prisma/migrations/**",
        "scripts/generate-test-template-db.ts",
        "scripts/check-test-template-db.ts",
        "src/testing/template.db"
      ]
    }
  }
}
