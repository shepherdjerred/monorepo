---
import { fetchQuotes } from "@data/market";

const quotes = await fetchQuotes();

function fmtPrice(n: number): string {
  return n.toLocaleString("en-US", {
    style: "currency",
    currency: "USD",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
}

function fmtPct(n: number): string {
  const sign = n >= 0 ? "+" : "";
  return `${sign}${n.toFixed(2)}%`;
}
---

<div class="ticker-tape" aria-hidden="true">
  <div class="ticker-track">
    {
      [...quotes, ...quotes].map((q) => (
        <span class="ticker-item">
          <span class="ticker-sym">{q.symbol}</span>
          <span class="tabular-nums">{fmtPrice(q.price)}</span>
          <span
            class="tabular-nums text-xs"
            style={`color: ${q.changePct >= 0 ? "var(--color-up)" : "var(--color-down)"}`}
          >
            {fmtPct(q.changePct)}
          </span>
        </span>
      ))
    }
  </div>
</div>
