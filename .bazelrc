# Bazel configuration for monorepo

# Use bzlmod for dependency management
build --enable_bzlmod

# Hermetic builds
build --incompatible_strict_action_env

# Workspace status for build stamping
build --workspace_status_command=tools/bazel/workspace_status.sh

# Allow empty globs (many packages may or may not have .tsx, .astro, etc.)
build --noincompatible_disallow_empty_glob

# Test output
test --test_output=errors

# Performance
build --jobs=auto
build --experimental_remote_merkle_tree_cache

# Convenience
build --color=yes
test --color=yes

# Remote cache (bazel-remote -> SeaweedFS S3)
# Local dev can use the Tailscale ingress; CI uses the in-cluster service URL.
# build --remote_cache=https://bazel-remote.tailnet-1a49.ts.net

# TypeScript
build --@aspect_rules_ts//ts:skipLibCheck=always
# Use tsc as the default transpiler for ts_project rules
common --@aspect_rules_ts//ts:default_to_tsc_transpiler

# CI-specific settings
# Remote cache via bazel-remote (enable after deploying bazel-remote service)
# build:ci --remote_cache=http://bazel-remote.bazel-remote.svc.cluster.local:8080
# build:ci --remote_upload_local_results=true
build:ci --disk_cache=/tmp/bazel-disk-cache
build:ci --color=yes
test:ci --test_output=all

# Local development
build:local --disk_cache=~/.cache/bazel-disk
